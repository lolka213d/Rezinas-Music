<UserControl x:Class="Harmony.Views.HorizontalScrollRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Grid Margin="0,0,0,28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Button x:Name="LeftBtn" Grid.Column="0" Style="{StaticResource CarouselArrow}"
                Margin="0,0,6,0" VerticalAlignment="Center" Click="ScrollLeft"
                Visibility="Collapsed" ToolTip="Scroll left">
            <Path Data="{StaticResource IconChevronLeft}" Style="{StaticResource IconPath}" Width="16" Height="16" />
        </Button>

        <ScrollViewer x:Name="Scroller" Grid.Column="1"
                      HorizontalScrollBarVisibility="Hidden"
                      VerticalScrollBarVisibility="Disabled"
                      PanningMode="HorizontalOnly"
                      PreviewMouseWheel="OnPreviewMouseWheel">
            <ItemsControl ItemsSource="{Binding ItemsSource, ElementName=Root}"
                          ItemTemplate="{Binding ItemTemplate, ElementName=Root}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <Button x:Name="RightBtn" Grid.Column="2" Style="{StaticResource CarouselArrow}"
                Margin="6,0,0,0" VerticalAlignment="Center" Click="ScrollRight"
                Visibility="Collapsed" ToolTip="Scroll right">
            <Path Data="{StaticResource IconChevronRight}" Style="{StaticResource IconPath}" Width="16" Height="16" />
        </Button>
    </Grid>
</UserControl>
