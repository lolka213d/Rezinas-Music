<UserControl x:Class="Harmony.Views.ArtistDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Harmony.ViewModels"
             xmlns:views="clr-namespace:Harmony.Views">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,40">
            <Button Style="{StaticResource OutlineButton}" Content="← Back"
                    Command="{Binding GoBackCommand}" HorizontalAlignment="Left" Padding="14,6" Margin="0,0,0,20" />

            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="180" Height="180" CornerRadius="90"
                        Background="{StaticResource SurfaceHoverBrush}" Margin="0,0,24,0">
                    <Grid>
                        <Path Data="{StaticResource IconAccount}" Fill="{StaticResource TextSecondaryBrush}"
                              Stretch="Uniform" Width="64" Height="64" />
                        <Image Source="{Binding ThumbnailUrl}" Stretch="UniformToFill" />
                    </Grid>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="ARTIST" Style="{StaticResource Subtle}" FontWeight="Bold" FontSize="12" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding Name}" FontSize="42" FontWeight="Bold" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding MetaLine}" Style="{StaticResource Subtle}" Margin="0,8,0,0" />
                </StackPanel>
            </Grid>

            <Button Style="{StaticResource PlayButton}" Command="{Binding PlayCommand}" HorizontalAlignment="Left" Margin="0,0,0,24">
                <Path Data="{StaticResource IconPlay}" Fill="Black" Stretch="Uniform" Width="22" Height="22" />
            </Button>

            <TextBlock Text="Popular" Style="{StaticResource SectionTitle}" />
            <ListBox ItemsSource="{Binding TopTracks}" Style="{StaticResource TrackListBox}" Margin="0,0,0,20">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Style="{StaticResource IconButton}" Width="32" Height="32"
                                    Command="{Binding DataContext.PlayTrackCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}">
                                <Path Style="{StaticResource IconPath}" Data="{StaticResource IconPlay}" Width="14" Height="14" />
                            </Button>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding InfoLine}" Style="{StaticResource Subtle}" FontSize="12" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="{Binding DurationDisplay}" Style="{StaticResource Subtle}" VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock Text="Albums" Style="{StaticResource SectionTitle}" />
            <views:HorizontalScrollRow ItemsSource="{Binding Albums}">
                <views:HorizontalScrollRow.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:HomeAlbumCard}">
                        <views:AlbumCard
                            PlayCommand="{Binding DataContext.OpenAlbumCommand, RelativeSource={RelativeSource AncestorType={x:Type views:ArtistDetailView}}}"
                            CommandParameter="{Binding}"
                            Title="{Binding Title}"
                            ArtistName="{Binding ArtistName}"
                            ThumbnailUrl="{Binding ThumbnailUrl}" />
                    </DataTemplate>
                </views:HorizontalScrollRow.ItemTemplate>
            </views:HorizontalScrollRow>
        </StackPanel>
    </ScrollViewer>
</UserControl>
