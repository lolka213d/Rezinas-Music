<UserControl x:Class="Harmony.Views.SearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Harmony.ViewModels"
             xmlns:views="clr-namespace:Harmony.Views"
             xmlns:img="clr-namespace:Harmony.Helpers">
    <UserControl.Resources>
        <Style x:Key="SearchTabChip" TargetType="Button" BasedOn="{StaticResource FilterChip}">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinWidth" Value="72" />
            <Style.Triggers>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource FilterChipSelected}">
                            <Binding Path="CommandParameter" RelativeSource="{RelativeSource Self}" />
                            <Binding Path="SelectedTab" />
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                    <Setter Property="Foreground" Value="White" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Search bar -->
        <Border Grid.Row="0" Style="{StaticResource HarmonyPillSearch}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Style="{StaticResource IconButton}" Width="40" Height="40"
                        Command="{Binding BackFromResultsCommand}"
                        Visibility="{Binding ShowResultsPage, Converter={StaticResource BoolToVisibility}}">
                    <Path Data="{StaticResource IconChevronLeft}" Fill="{StaticResource TextPrimaryBrush}"
                          Stretch="Uniform" Width="20" Height="20" />
                </Button>
                <Path Grid.Column="0" Data="{StaticResource IconSearch}" Fill="{StaticResource TextMutedBrush}"
                      Stretch="Uniform" Width="18" Height="18" Margin="8,0,4,0"
                      Visibility="{Binding ShowResultsPage, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}" />
                <TextBox Grid.Column="1" Background="Transparent" BorderThickness="0"
                         VerticalContentAlignment="Center" FontSize="15" Padding="8,10"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         Tag="{Binding SearchPlaceholder}"
                         Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SearchAsyncCommand}" />
                    </TextBox.InputBindings>
                </TextBox>
                <Button Grid.Column="2" Style="{StaticResource IconButton}" Width="36" Height="36"
                        Command="{Binding ClearQueryCommand}"
                        Visibility="{Binding Query, Converter={StaticResource NullToVisibility}}">
                    <Path Data="{StaticResource IconClose}" Fill="{StaticResource TextMutedBrush}"
                          Stretch="Uniform" Width="16" Height="16" />
                </Button>
                <Button Grid.Column="3" Style="{StaticResource PillButton}" Content="{Binding Loc.CommonSearch}"
                        Command="{Binding SearchAsyncCommand}" Margin="4,0,4,0" Padding="16,8" />
            </Grid>
        </Border>

        <!-- Live suggestions (no saved history) -->
        <StackPanel Grid.Row="1" Visibility="{Binding ShowIdleSearch, Converter={StaticResource BoolToVisibility}}">
            <ItemsControl ItemsSource="{Binding Suggestions}" Margin="0,0,0,0"
                          Visibility="{Binding ShowSuggestions, Converter={StaticResource BoolToVisibility}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource HarmonySuggestionPill}"
                                MouseLeftButtonUp="OnSuggestionClick" Tag="{Binding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Path Grid.Column="0" Data="{StaticResource IconSearch}" Fill="{StaticResource TextMutedBrush}"
                                      Stretch="Uniform" Width="16" Height="16" Margin="0,0,12,0" />
                                <TextBlock Grid.Column="1" Text="{Binding}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <Path Grid.Column="2" Data="{StaticResource IconChevronRight}" Fill="{StaticResource TextMutedBrush}"
                                      Stretch="Uniform" Width="16" Height="16" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- Results (Spotify-style) -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding ShowResultsPage, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
                <!-- Filter chips -->
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="{Binding TabAllLabel}" Command="{Binding SelectTabCommand}"
                                CommandParameter="{x:Static vm:SearchTab.All}" Style="{StaticResource SearchTabChip}" />
                        <Button Content="{Binding TabTracksLabel}" Command="{Binding SelectTabCommand}"
                                CommandParameter="{x:Static vm:SearchTab.Tracks}" Style="{StaticResource SearchTabChip}" />
                        <Button Content="{Binding TabAlbumsLabel}" Command="{Binding SelectTabCommand}"
                                CommandParameter="{x:Static vm:SearchTab.Albums}" Style="{StaticResource SearchTabChip}" />
                        <Button Content="{Binding TabArtistsLabel}" Command="{Binding SelectTabCommand}"
                                CommandParameter="{x:Static vm:SearchTab.Artists}" Style="{StaticResource SearchTabChip}" />
                        <Button Content="{Binding TabPodcastsLabel}" Command="{Binding SelectTabCommand}"
                                CommandParameter="{x:Static vm:SearchTab.Podcasts}" Style="{StaticResource SearchTabChip}" />
                    </StackPanel>
                </ScrollViewer>

                <!-- Top result hero -->
                <Border CornerRadius="8" Background="#FF282828" Padding="20" Margin="0,0,0,24"
                        Visibility="{Binding HasFeaturedTrack, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Width="92" Height="92" CornerRadius="6" ClipToBounds="True">
                            <Grid>
                                <Path Data="{StaticResource IconNote}" Fill="{StaticResource TextMutedBrush}"
                                      Stretch="Uniform" Width="28" Height="28" />
                                <Image img:ImageLoader.SourceUrl="{Binding FeaturedTrack.ThumbnailUrl}"
                                       img:ImageLoader.DecodeWidth="184" Stretch="UniformToFill" />
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="20,0,16,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding TopResultLabel}" FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6" />
                            <TextBlock Text="{Binding FeaturedTrack.Title}" FontSize="28" FontWeight="Bold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding FeaturedSubtitle}" Style="{StaticResource Muted}" FontSize="14" Margin="0,6,0,0" />
                        </StackPanel>
                        <Button Grid.Column="2" Width="56" Height="56" VerticalAlignment="Center"
                                Command="{Binding PlayFeaturedCommand}" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Width="56" Height="56" CornerRadius="28" Background="#FF1DB954">
                                        <Path Data="{StaticResource IconPlay}" Fill="Black" Stretch="Uniform"
                                              Width="22" Height="22" Margin="4,0,0,0"
                                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- Tracks -->
                <TextBlock Text="{Binding TabTracksLabel}" FontSize="22" FontWeight="Bold" Margin="0,0,0,12"
                           Visibility="{Binding HasTracks, Converter={StaticResource BoolToVisibility}}" />
                <ItemsControl ItemsSource="{Binding Results}" Margin="0,0,0,20"
                              Visibility="{Binding HasTracks, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,6" CornerRadius="6" Margin="0,0,0,2" Background="Transparent">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#18FFFFFF" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid MinHeight="56">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="52" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="100" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="4" ClipToBounds="True" IsHitTestVisible="False">
                                        <Grid>
                                            <Path Data="{StaticResource IconNote}" Fill="{StaticResource TextMutedBrush}" Stretch="Uniform" Width="16" Height="16" />
                                            <Image img:ImageLoader.SourceUrl="{Binding ThumbnailUrl}"
                                                   img:ImageLoader.DecodeWidth="128" Stretch="UniformToFill" />
                                            <Border Background="#99000000" Visibility="Collapsed">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border, AncestorLevel=2}}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Path Data="{StaticResource IconPlay}" Fill="White" Stretch="Uniform"
                                                      Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,8,0" IsHitTestVisible="False">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="15" />
                                        <TextBlock Text="{Binding ArtistName}" Style="{StaticResource Muted}" FontSize="13" />
                                    </StackPanel>
                                    <Border Grid.Column="2" Background="#FF333333" CornerRadius="4" Padding="10,4"
                                            VerticalAlignment="Center" Margin="0,0,12,0" IsHitTestVisible="False">
                                        <TextBlock Text="{Binding DataContext.TrackTypeLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   FontSize="12" FontWeight="SemiBold" />
                                    </Border>
                                    <TextBlock Grid.Column="3" Text="{Binding DurationDisplay}"
                                               VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource Muted}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Button Grid.Column="3" Width="32" Height="32"
                                            HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="Collapsed"
                                            Command="{Binding DataContext.AddToPlaylistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" ToolTip="{Binding DataContext.Loc.TipAddPlaylist, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Path Data="{StaticResource IconAdd}" Fill="{StaticResource TextSecondaryBrush}"
                                              Stretch="Uniform" Width="18" Height="18" />
                                    </Button>
                                    <Button Grid.Column="0" Grid.ColumnSpan="4" Style="{StaticResource TrackRowHitButton}"
                                            Command="{Binding DataContext.PlayCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Albums -->
                <TextBlock Text="{Binding TabAlbumsLabel}" FontSize="22" FontWeight="Bold" Margin="0,0,0,12"
                           Visibility="{Binding HasAlbums, Converter={StaticResource BoolToVisibility}}" />
                <ItemsControl ItemsSource="{Binding AlbumResults}" Margin="0,0,0,20"
                              Visibility="{Binding HasAlbums, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:HomeAlbumCard}">
                            <views:AlbumCard
                                PlayCommand="{Binding DataContext.OpenAlbumCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                Title="{Binding Title}"
                                ArtistName="{Binding ArtistName}"
                                ThumbnailUrl="{Binding ThumbnailUrl}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Artists -->
                <TextBlock Text="{Binding TabArtistsLabel}" FontSize="22" FontWeight="Bold" Margin="0,0,0,12"
                           Visibility="{Binding HasArtists, Converter={StaticResource BoolToVisibility}}" />
                <ItemsControl ItemsSource="{Binding ArtistResults}" Margin="0,0,0,8"
                              Visibility="{Binding HasArtists, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:SearchArtistCard}">
                            <Border Padding="8,6" CornerRadius="6" Margin="0,0,0,2" Background="Transparent" Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.OpenArtistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}" />
                                </Border.InputBindings>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#18FFFFFF" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid MinHeight="56">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="52" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="44" Height="44" CornerRadius="22" ClipToBounds="True">
                                        <Image img:ImageLoader.SourceUrl="{Binding ThumbnailUrl}"
                                               img:ImageLoader.DecodeWidth="128" Stretch="UniformToFill" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,8,0">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="15" />
                                        <TextBlock Text="{Binding TabArtistsLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   Style="{StaticResource Muted}" FontSize="13" />
                                    </StackPanel>
                                    <Border Grid.Column="2" Background="#FF333333" CornerRadius="4" Padding="10,4" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding TabArtistsLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   FontSize="12" FontWeight="SemiBold" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource Muted}" Margin="0,8,0,0" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
