<Window x:Class="Harmony.Views.MiniPlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:img="clr-namespace:Harmony.Helpers"
        Title="Rezinas Music"
        Width="360" Height="96"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ResizeMode="NoResize" ShowInTaskbar="False">
    <Border CornerRadius="14" Background="#E6121218" BorderBrush="#33FFFFFF" BorderThickness="1" Padding="12,8">
        <Grid DataContext="{Binding Player}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Width="40" Height="40" CornerRadius="8" ClipToBounds="True">
                <Image img:ImageLoader.SourceUrl="{Binding CurrentTrack.ThumbnailUrl}"
                       img:ImageLoader.DecodeWidth="80" Stretch="UniformToFill" />
            </Border>
            <StackPanel Grid.Column="1" Margin="10,0,8,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding CurrentTrack.Title}" FontWeight="SemiBold" FontSize="13"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding CurrentTrack.ArtistName}" Foreground="#99FFFFFF" FontSize="11"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Width="36" Height="36" Command="{Binding PreviousCommand}" Style="{StaticResource IconButton}">
                    <Path Data="{StaticResource IconPrevious}" Fill="White" Stretch="Uniform" Width="16" Height="16" />
                </Button>
                <Button Width="40" Height="40" Command="{Binding PlayPauseCommand}" Style="{StaticResource IconButton}" Margin="4,0">
                    <Path Data="{StaticResource IconPlay}" Fill="White" Stretch="Uniform" Width="18" Height="18" />
                </Button>
                <Button Width="36" Height="36" Command="{Binding NextCommand}" Style="{StaticResource IconButton}">
                    <Path Data="{StaticResource IconNext}" Fill="White" Stretch="Uniform" Width="16" Height="16" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
