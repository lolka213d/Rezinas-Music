<UserControl x:Class="Harmony.Views.PlayerBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:img="clr-namespace:Harmony.Helpers"
             xmlns:views="clr-namespace:Harmony.Views"
             MinHeight="84"
             ClipToBounds="False">
    <Border Style="{StaticResource GlassPlayerBar}" ClipToBounds="False">
        <Grid ClipToBounds="False">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" MinWidth="180" />
                <ColumnDefinition Width="3.6*" MinWidth="300" />
                <ColumnDefinition Width="2*" MinWidth="160" />
            </Grid.ColumnDefinitions>

            <!-- Left: cover + meta + like -->
            <Grid Grid.Column="0" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" Cursor="Hand">
                    <Button Style="{StaticResource TrackRowHitButton}"
                            Command="{Binding OpenNowPlayingCommand}"
                            IsEnabled="{Binding HasTrack}" />
                    <StackPanel Orientation="Horizontal" IsHitTestVisible="False">
                        <Border Width="52" Height="52" CornerRadius="10" ClipToBounds="True" Background="#14FFFFFF">
                            <Grid>
                                <Path Data="{StaticResource IconNote}" Fill="{StaticResource TextMutedBrush}"
                                      Stretch="Uniform" Width="18" Height="18" />
                                <Image img:ImageLoader.SourceUrl="{Binding CurrentTrack.ThumbnailUrl}"
                                       img:ImageLoader.DecodeWidth="104" Stretch="UniformToFill" />
                            </Grid>
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center" MaxWidth="200">
                            <TextBlock Text="{Binding CurrentTrack.Title, FallbackValue='Rezinas Music'}"
                                       FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding CurrentTrack.ArtistName, FallbackValue='Выберите трек'}"
                                       Style="{StaticResource RzMeta}" FontSize="12" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
                <views:FavoriteHeart Grid.Column="1" Margin="8,0,0,0"
                                     Track="{Binding CurrentTrack}"
                                     Command="{Binding ToggleFavoriteCommand}"
                                     Visibility="{Binding HasTrack, Converter={StaticResource BoolToVisibility}}" />
            </Grid>

            <!-- Center: transport + progress -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Style="{StaticResource IconButton}" Command="{Binding ToggleShuffleCommand}" Width="34" Height="34">
                        <Path Data="{StaticResource IconShuffle}" Stretch="Uniform" Width="15" Height="15">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Fill" Value="{StaticResource TextSecondaryBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsShuffle}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource AccentCyanBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding PreviousCommand}" IsEnabled="{Binding HasTrack}"
                            Margin="8,0" Width="36" Height="36">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource IconPrevious}" Width="16" Height="16" />
                    </Button>
                    <Button Style="{StaticResource RzPlayerPlayButton}" Margin="10,0"
                            Command="{Binding PlayPauseCommand}" IsEnabled="{Binding HasTrack}">
                        <Path Stretch="Uniform" Width="18" Height="18" Fill="White">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Data" Value="{StaticResource IconPlay}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                            <Setter Property="Data" Value="{StaticResource IconPause}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding NextCommand}" IsEnabled="{Binding HasTrack}"
                            Width="36" Height="36">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource IconNext}" Width="16" Height="16" />
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding ToggleRepeatCommand}" Margin="8,0,0,0" Width="34" Height="34"
                            ToolTip="{Binding RepeatModeHint}">
                        <Grid Width="15" Height="15">
                            <Path Data="{StaticResource IconRepeat}" Stretch="Uniform"
                                  Visibility="{Binding IsRepeatAll, Converter={StaticResource BoolToVisibility}}">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Fill" Value="{StaticResource AccentCyanBrush}" />
                                    </Style>
                                </Path.Style>
                            </Path>
                            <Path Data="{StaticResource IconRepeatOne}" Stretch="Uniform"
                                  Visibility="{Binding IsRepeatOne, Converter={StaticResource BoolToVisibility}}">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Fill" Value="{StaticResource AccentCyanBrush}" />
                                    </Style>
                                </Path.Style>
                            </Path>
                            <Path Data="{StaticResource IconRepeat}" Stretch="Uniform"
                                  Visibility="{Binding IsRepeatOff, Converter={StaticResource BoolToVisibility}}">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Fill" Value="{StaticResource TextSecondaryBrush}" />
                                    </Style>
                                </Path.Style>
                            </Path>
                        </Grid>
                    </Button>
                </StackPanel>

                <Grid Margin="0,8,0,0" Height="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding PositionDisplay}" Style="{StaticResource RzMeta}" FontSize="10"
                               VerticalAlignment="Center" />
                    <Slider x:Name="ProgressSlider" Grid.Column="1" Margin="6,0" Minimum="0"
                            Maximum="{Binding ProgressMaximum}"
                            Value="{Binding PositionSeconds, Mode=TwoWay}"
                            Style="{StaticResource MediaSlider}"
                            IsEnabled="{Binding HasTrack}"
                            VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="{Binding DurationDisplay}" Style="{StaticResource RzMeta}" FontSize="10"
                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                </Grid>
            </StackPanel>

            <!-- Right: lyrics + volume -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Style="{StaticResource IconButton}" Width="32" Height="32" ToolTip="Текст песни"
                        Command="{Binding DataContext.Lyrics.ToggleCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                    <Path Data="{StaticResource IconMic}" Fill="{StaticResource TextMutedBrush}" Stretch="Uniform" Width="15" Height="15" />
                </Button>
                <Path Data="{StaticResource IconVolume}" Fill="{StaticResource TextMutedBrush}"
                      Stretch="Uniform" Width="15" Height="15" Margin="12,0,0,0" VerticalAlignment="Center" />
                <Slider x:Name="VolumeSlider" Width="96" Minimum="0" Maximum="1" Margin="8,0,0,0"
                        Value="{Binding Volume, Mode=TwoWay}"
                        Style="{StaticResource MediaSlider}"
                        VerticalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
