<UserControl x:Class="Harmony.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Harmony.ViewModels"
             xmlns:models="clr-namespace:Harmony.Models">
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="{Binding Loc.SettingsTitle}" FontSize="32" FontWeight="Bold" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Style="{StaticResource RzSettingsSidebar}">
                <StackPanel>
                    <Button Content="{Binding TabProfileLabel}" Command="{Binding SelectTabCommand}" CommandParameter="{x:Static vm:SettingsTab.Profile}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SettingsNavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTab}" Value="{x:Static vm:SettingsTab.Profile}">
                                        <Setter Property="Background" Value="#228B5CF6" />
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="{Binding TabLookLabel}" Command="{Binding SelectTabCommand}" CommandParameter="{x:Static vm:SettingsTab.Look}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SettingsNavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTab}" Value="{x:Static vm:SettingsTab.Look}">
                                        <Setter Property="Background" Value="#228B5CF6" />
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="{Binding TabPlaybackLabel}" Command="{Binding SelectTabCommand}" CommandParameter="{x:Static vm:SettingsTab.Playback}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SettingsNavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTab}" Value="{x:Static vm:SettingsTab.Playback}">
                                        <Setter Property="Background" Value="#228B5CF6" />
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="{Binding TabInterfaceLabel}" Command="{Binding SelectTabCommand}" CommandParameter="{x:Static vm:SettingsTab.Interface}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SettingsNavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTab}" Value="{x:Static vm:SettingsTab.Interface}">
                                        <Setter Property="Background" Value="#228B5CF6" />
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="{Binding TabDataLabel}" Command="{Binding SelectTabCommand}" CommandParameter="{x:Static vm:SettingsTab.Data}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SettingsNavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTab}" Value="{x:Static vm:SettingsTab.Data}">
                                        <Setter Property="Background" Value="#228B5CF6" />
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <Border Style="{StaticResource RzSettingsSection}" MaxWidth="760">
                    <StackPanel>
                        <!-- Profile -->
                        <StackPanel Visibility="{Binding IsProfileTab, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding Loc.SettingsProfile}" FontWeight="Bold" FontSize="20" Margin="0,0,0,16" />
                            <TextBlock Text="{Binding Loc.SettingsUsername}" Style="{StaticResource Muted}" Margin="0,0,0,6" />
                            <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20" MaxWidth="400" HorizontalAlignment="Left" />
                            <TextBlock Text="{Binding Loc.SettingsAvatar}" Style="{StaticResource Muted}" Margin="0,0,0,10" />
                            <StackPanel Orientation="Horizontal">
                                <Border Width="80" Height="80" CornerRadius="40" ClipToBounds="True"
                                        BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1">
                                    <Grid>
                                        <Path Data="{StaticResource IconAccount}" Fill="{StaticResource TextMutedBrush}"
                                              Stretch="Uniform" Width="34" Height="34" />
                                        <Image Source="{Binding AvatarPath}" Stretch="UniformToFill" />
                                    </Grid>
                                </Border>
                                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                    <Button Style="{StaticResource OutlineButton}" Content="{Binding Loc.SettingsPickAvatar}"
                                            Command="{Binding PickAvatarCommand}" Padding="16,8" />
                                    <Button Style="{StaticResource OutlineButton}" Content="{Binding Loc.CommonDelete}"
                                            Command="{Binding ClearAvatarCommand}" Margin="0,8,0,0" Padding="16,8"
                                            HorizontalAlignment="Left"
                                            Visibility="{Binding AvatarPath, Converter={StaticResource NullToVisibility}}" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- Look -->
                        <StackPanel Visibility="{Binding IsLookTab, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding Loc.SettingsAppearance}" FontWeight="Bold" FontSize="20" Margin="0,0,0,16" />
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Loc.SettingsDarkTheme}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Loc.SettingsDarkThemeHint}" Style="{StaticResource Muted}" FontSize="12" Margin="0,4,0,0" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource GlassToggle}" IsChecked="{Binding IsDarkTheme}" />
                            </Grid>
                            <TextBlock Text="{Binding Loc.SettingsLanguage}" Style="{StaticResource Muted}" Margin="0,0,0,8" />
                            <ComboBox ItemsSource="{Binding LanguageOptions}" SelectedValue="{Binding Language}"
                                      SelectedValuePath="Code" DisplayMemberPath="Name" Width="280" HorizontalAlignment="Left" />
                        </StackPanel>

                        <!-- Playback -->
                        <StackPanel Visibility="{Binding IsPlaybackTab, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding Loc.SettingsPlayback}" FontWeight="Bold" FontSize="20" Margin="0,0,0,16" />
                            <TextBlock Text="{Binding Loc.SettingsQuality}" Style="{StaticResource Muted}" Margin="0,0,0,8" />
                            <ComboBox ItemsSource="{Binding QualityOptions}" SelectedItem="{Binding AudioQuality}"
                                      Width="240" HorizontalAlignment="Left" Margin="0,0,0,20"
                                      MaxDropDownHeight="200">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:AudioQuality}">
                                        <TextBlock>
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource AudioQualityLabel}">
                                                    <Binding />
                                                    <Binding Path="DataContext.Language" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Text="{Binding Loc.SettingsPlaybackSpeed}" Style="{StaticResource Muted}" Margin="0,0,0,8" />
                            <ComboBox ItemsSource="{Binding SpeedOptions}" SelectedItem="{Binding PlaybackSpeed}"
                                      Width="140" HorizontalAlignment="Left" Margin="0,0,0,20" />
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Loc.SettingsRadio}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <CheckBox Grid.Column="1" Style="{StaticResource GlassToggle}" IsChecked="{Binding RadioEnabled}" />
                            </Grid>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Loc.SettingsLyricsOffset}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Loc.SettingsSeconds}" Style="{StaticResource Muted}" FontSize="12" Margin="0,2,0,0" />
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding LyricsOffsetSeconds, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Loc.SettingsCrossfade}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Loc.SettingsMilliseconds}" Style="{StaticResource Muted}" FontSize="12" Margin="0,2,0,0" />
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding CrossfadeMs, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SleepTimerLabel}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding SleepTimerOffLabel}" Style="{StaticResource Muted}" FontSize="12" Margin="0,2,0,0" />
                                </StackPanel>
                                <ComboBox Grid.Column="1" ItemsSource="{Binding SleepTimerOptions}"
                                          SelectedItem="{Binding SleepTimerMinutes}" Width="120" />
                            </Grid>
                        </StackPanel>

                        <!-- Interface -->
                        <StackPanel Visibility="{Binding IsInterfaceTab, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding Loc.SettingsInterface}" FontWeight="Bold" FontSize="20" Margin="0,0,0,16" />
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding MiniTrayLabel}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <CheckBox Grid.Column="1" Style="{StaticResource GlassToggle}" IsChecked="{Binding MiniPlayerInTray}" />
                            </Grid>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding CompactListsLabel}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <CheckBox Grid.Column="1" Style="{StaticResource GlassToggle}" IsChecked="{Binding CompactTrackLists}" />
                            </Grid>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Loc.SettingsShowHomeAlbums}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Loc.SettingsShowHomeAlbumsHint}" Style="{StaticResource Muted}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource GlassToggle}" IsChecked="{Binding ShowHomeAlbums}" />
                            </Grid>
                            <TextBlock Text="{Binding HotkeysLabel}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding HotkeysHint}" Style="{StaticResource Muted}" FontSize="12" Margin="0,6,0,16" TextWrapping="Wrap" />
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Loc.SettingsMediaKeys}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Loc.SettingsMediaKeysHint}" Style="{StaticResource Muted}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource GlassToggle}" IsChecked="{Binding MediaKeysEnabled}" />
                            </Grid>
                        </StackPanel>

                        <!-- Data -->
                        <StackPanel Visibility="{Binding IsDataTab, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding Loc.SettingsData}" FontWeight="Bold" FontSize="20" Margin="0,0,0,16" />
                            <TextBlock Text="{Binding Loc.SettingsLogs}" Style="{StaticResource Muted}" />
                            <TextBlock Text="{Binding LogFilePath}" Style="{StaticResource Muted}" FontSize="11"
                                       TextWrapping="Wrap" Margin="0,4,0,12" />
                            <Button Style="{StaticResource OutlineButton}" Content="{Binding Loc.SettingsOpenLogs}"
                                    Command="{Binding OpenLogsFolderCommand}" HorizontalAlignment="Left"
                                    Padding="14,8" Margin="0,0,0,24" />
                            <TextBlock Text="{Binding Loc.SettingsAbout}" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <TextBlock Style="{StaticResource Muted}" Margin="0,0,0,12">
                                <Run Text="{Binding Loc.SettingsVersion, Mode=OneWay}" />
                                <Run Text=" " />
                                <Run Text="{Binding AppVersion, Mode=OneWay}" />
                            </TextBlock>
                            <CheckBox Content="{Binding CheckUpdatesLabel}" IsChecked="{Binding CheckForUpdates}"
                                      Style="{StaticResource GlassToggle}" Margin="0,0,0,12" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Button Style="{StaticResource OutlineButton}" Content="{Binding CheckUpdatesNowLabel}"
                                        Command="{Binding CheckForUpdatesNowCommand}" Padding="14,8" />
                                <TextBlock Text="{Binding UpdateStatusMessage}" Style="{StaticResource Muted}"
                                           VerticalAlignment="Center" Margin="14,0,0,0" />
                            </StackPanel>
                            <TextBlock Text="{Binding StatsTitle}" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <TextBlock Text="{Binding StatsSummary}" Style="{StaticResource Muted}" Margin="0,0,0,20" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SupportTitle}" FontWeight="Bold" FontSize="18" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding SupportHint}" Style="{StaticResource Muted}" TextWrapping="Wrap"
                                       Margin="0,0,0,14" MaxWidth="520" />
                            <ItemsControl ItemsSource="{Binding SupportLinks}" Margin="0,0,0,24">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:SupportLinkItem}">
                                        <Button Style="{StaticResource OutlineButton}" Content="{Binding Title}"
                                                Command="{Binding DataContext.OpenSupportLinkCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Url}" Padding="16,10" Margin="0,0,10,10"
                                                HorizontalAlignment="Left" MinWidth="140" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                            <WrapPanel>
                                <Button Style="{StaticResource OutlineButton}" Content="{Binding Loc.SettingsClearCache}"
                                        Command="{Binding ClearCacheCommand}" Margin="0,0,10,10" Padding="14,8" />
                                <Button Style="{StaticResource OutlineButton}" Content="{Binding Loc.SettingsClearHistory}"
                                        Command="{Binding ClearHistoryCommand}" Margin="0,0,10,10" Padding="14,8" />
                                <Button Style="{StaticResource OutlineButton}" Content="{Binding Loc.SettingsClearFavorites}"
                                        Command="{Binding ClearFavoritesCommand}" Margin="0,0,10,10" Padding="14,8" />
                                <Button Style="{StaticResource OutlineButton}" Content="{Binding Loc.SettingsResetDefaults}"
                                        Command="{Binding ResetDefaultsCommand}" Margin="0,0,10,10" Padding="14,8" />
                            </WrapPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </Grid>

        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Style="{StaticResource Subtle}"
                   Foreground="{StaticResource AccentBrush}" Margin="0,14,0,0" FontSize="13" />
    </Grid>
</UserControl>
