<UserControl x:Class="Harmony.Views.AlbumDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Harmony.Views"
             xmlns:cmp="clr-namespace:Harmony.Components"
             xmlns:img="clr-namespace:Harmony.Helpers"
             Loaded="OnLoaded">
    <Grid ClipToBounds="True" Background="{StaticResource AppBackgroundBrush}">
        <!-- Subtle backdrop (no full-size image — avoids layout blow-up) -->
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF07080D" Offset="0" />
                    <GradientStop Color="#FF0B0D14" Offset="0.45" />
                    <GradientStop Color="#FF1A1030" Offset="1" />
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Grid Margin="{StaticResource PagePadding}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Button Grid.Row="0" Style="{StaticResource OutlineButton}" Content="← Back"
                    Command="{Binding GoBackCommand}" HorizontalAlignment="Left"
                    Padding="14,6" Margin="0,0,0,16" Opacity="0" x:Name="BackButton" />

            <Grid Grid.Row="1" x:Name="MainContent" Opacity="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" MinWidth="240" MaxWidth="380" />
                    <ColumnDefinition Width="1.15*" MinWidth="280" />
                    <ColumnDefinition Width="0.95*" MinWidth="300" MaxWidth="440" />
                </Grid.ColumnDefinitions>

                <!-- Left: lyrics -->
                <Border Grid.Column="0" Style="{StaticResource GlassPanel}" Padding="16" Margin="0,0,12,0"
                        BorderBrush="#18FFFFFF" BorderThickness="1" MinHeight="400">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="{Binding LyricsTitle}" FontWeight="Bold" FontSize="16" Margin="0,0,0,12" />
                        <TextBlock Grid.Row="1" Text="Загрузка…" Style="{StaticResource Muted}"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   Visibility="{Binding IsLyricsLoading, Converter={StaticResource BoolToVisibility}}" />
                        <TextBlock Grid.Row="1" Text="{Binding LyricsStatus}" Style="{StaticResource Muted}"
                                   VerticalAlignment="Center" TextWrapping="Wrap"
                                   Visibility="{Binding ShowLyricsEmpty, Converter={StaticResource BoolToVisibility}}" />
                        <ListBox x:Name="LyricsList" Grid.Row="1"
                                 ItemsSource="{Binding LyricLines}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.CanContentScroll="False">
                            <ListBox.Style>
                                <Style TargetType="ListBox">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLyricsLoading}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0,6" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontSize="15" LineHeight="22">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#FF6A6A6A" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPast}" Value="True">
                                                        <Setter Property="Foreground" Value="#FF8A8A8A" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Foreground" Value="White" />
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Center: track hero -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Margin="0,0,12,0" CanContentScroll="False">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="480">
                        <TextBlock Text="{Binding PageKindLabel}" Style="{StaticResource Muted}" FontSize="11"
                                   FontWeight="Bold" Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding Title}" FontSize="28" FontWeight="Bold"
                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,20" />

                        <Border Width="300" Height="300" CornerRadius="22" Margin="0,0,0,24"
                                HorizontalAlignment="Center" x:Name="CoverBorder"
                                BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1"
                                ClipToBounds="True" RenderTransformOrigin="0.5,0.5">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#14FFFFFF" />
                                    <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="1" ScaleY="1" />
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.55" Color="#FF7C3AED" />
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <EventTrigger RoutedEvent="MouseEnter">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                     To="1.03" Duration="0:0:0.2" />
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                     To="1.03" Duration="0:0:0.2" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                        <EventTrigger RoutedEvent="MouseLeave">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                     To="1" Duration="0:0:0.2" />
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                     To="1" Duration="0:0:0.2" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                        <DataTrigger Binding="{Binding IsFocusedTrackPlaying}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard Storyboard="{StaticResource PlayingPulse}" />
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Path Data="{StaticResource IconNote}" Fill="{StaticResource TextMutedBrush}"
                                      Stretch="Uniform" Width="80" Height="80" />
                                <Image img:ImageLoader.SourceUrl="{Binding HeroCoverUrl}"
                                       img:ImageLoader.DecodeWidth="320" Stretch="UniformToFill" />
                            </Grid>
                        </Border>

                        <TextBlock Text="{Binding FocusedTitle}" FontSize="24" FontWeight="Bold"
                                   TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,6" />
                        <TextBlock Text="{Binding FocusedArtistName}" Style="{StaticResource Subtle}"
                                   FontSize="16" TextAlignment="Center" Margin="0,0,0,10" />

                        <Border Width="64" Height="64" CornerRadius="32" ClipToBounds="True" Margin="0,0,0,12"
                                HorizontalAlignment="Center"
                                BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1"
                                Visibility="{Binding ArtistPictureUrl, Converter={StaticResource NullToVisibility}}">
                            <Image img:ImageLoader.SourceUrl="{Binding ArtistPictureUrl}"
                                   img:ImageLoader.DecodeWidth="128" Stretch="UniformToFill" />
                        </Border>
                        <TextBlock Text="{Binding ArtistBio}" Style="{StaticResource Muted}" FontSize="12"
                                   TextWrapping="Wrap" TextAlignment="Center" MaxWidth="360" Margin="0,0,0,12"
                                   Visibility="{Binding ArtistBio, Converter={StaticResource NullToVisibility}}" />
                        <TextBlock Text="{Binding FocusedInfoLine}" Style="{StaticResource Muted}"
                                   FontSize="12" TextAlignment="Center" Margin="0,0,0,16"
                                   Visibility="{Binding FocusedTrack, Converter={StaticResource NullToVisibility}}" />
                        <TextBlock Text="{Binding MetaLine}" Style="{StaticResource Muted}" FontSize="12"
                                   TextAlignment="Center" Margin="0,0,0,20" />

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Style="{StaticResource PlayButton}" Width="54" Height="54"
                                    Command="{Binding PlayTrackCommand}" CommandParameter="{Binding FocusedTrack}"
                                    IsEnabled="{Binding HasTracks}" ToolTip="Play">
                                <Path Data="{StaticResource IconPlay}" Fill="Black" Stretch="Uniform" Width="22" Height="22" />
                            </Button>
                            <Button Style="{StaticResource IconButton}" Width="48" Height="48" Margin="14,0,0,0"
                                    Command="{Binding ShuffleCommand}" IsEnabled="{Binding HasTracks}" ToolTip="Shuffle">
                                <Path Data="{StaticResource IconShuffle}" Style="{StaticResource IconPath}" />
                            </Button>
                            <Button Style="{StaticResource IconButton}" Width="48" Height="48" Margin="8,0,0,0"
                                    Command="{Binding ToggleFocusedFavoriteCommand}"
                                    ToolTip="Like">
                                <Path Stretch="Uniform" Width="20" Height="20">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Data" Value="{StaticResource IconHeart}" />
                                            <Setter Property="Fill" Value="{StaticResource TextMutedBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFocusedFavorite}" Value="True">
                                                    <Setter Property="Data" Value="{StaticResource IconHeartFilled}" />
                                                    <Setter Property="Fill" Value="{StaticResource AccentBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Button>
                        </StackPanel>

                        <TextBlock Text="{Binding DescriptionLine}" Style="{StaticResource Muted}" FontSize="11"
                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,20,0,0" MaxWidth="360"
                                   Visibility="{Binding DescriptionLine, Converter={StaticResource NullToVisibility}}" />
                    </StackPanel>
                </ScrollViewer>

                <!-- Right: track list -->
                <Border Grid.Column="2" Style="{StaticResource GlassPanel}" Padding="0" MinHeight="400"
                        BorderBrush="#18FFFFFF" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="18,18,18,12">
                            <TextBlock Text="Tracks" FontSize="18" FontWeight="Bold" />
                            <TextBlock Text="{Binding MetaLine}" Style="{StaticResource Muted}" FontSize="12" Margin="0,4,0,0" />
                        </StackPanel>

                        <TextBlock Grid.Row="1" Text="Loading…" Style="{StaticResource Muted}"
                                   Margin="18,0" VerticalAlignment="Top"
                                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" />

                        <ListBox Grid.Row="1" ItemsSource="{Binding Tracks}"
                                 Style="{StaticResource GlassTrackListBox}"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 SelectedItem="{Binding FocusedTrack, Mode=TwoWay}"
                                 Margin="8,0,4,12"
                                 Visibility="{Binding HasTracks, Converter={StaticResource BoolToVisibility}}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.InputBindings>
                                            <MouseBinding Gesture="LeftClick"
                                                          Command="{Binding DataContext.PlayTrackCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                          CommandParameter="{Binding}" />
                                        </Grid.InputBindings>
                                        <cmp:TrackRow Track="{Binding}"
                                                        ShowIndex="True"
                                                        ShowPlayButton="False"
                                                        CurrentTrack="{Binding DataContext.Player.CurrentTrack, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        Index="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=(ItemsControl.AlternationIndex), Converter={StaticResource TrackNumber}}" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
