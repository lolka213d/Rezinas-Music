<UserControl x:Class="Harmony.Views.AlbumCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:img="clr-namespace:Harmony.Helpers"
             Width="142" Margin="0,0,14,0">
    <Button Style="{StaticResource HarmonyAlbumCardButton}"
            Command="{Binding PlayCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
            CommandParameter="{Binding CommandParameter, RelativeSource={RelativeSource AncestorType=UserControl}}">
        <StackPanel>
            <Border Height="138" CornerRadius="16" ClipToBounds="True"
                    BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1">
                <Grid>
                    <Border Background="{StaticResource SurfaceHoverBrush}" />
                    <Path Data="{StaticResource IconNote}" Fill="{StaticResource TextMutedBrush}"
                          Stretch="Uniform" Width="40" Height="40" />
                    <Image img:ImageLoader.SourceUrl="{Binding ThumbnailUrl, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           img:ImageLoader.DecodeWidth="220" Stretch="UniformToFill" />
                    <Border CornerRadius="16">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#00000000" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                        <Setter Property="Background" Value="#77000000" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border Width="44" Height="44" CornerRadius="22"
                                Background="{StaticResource AccentBrush}"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Opacity="0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                            <Setter Property="Opacity" Value="1" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Path Data="{StaticResource IconPlay}" Fill="White" Stretch="Uniform"
                                  Width="18" Height="18" Margin="2,0,0,0" />
                        </Border>
                    </Border>
                </Grid>
            </Border>
            <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontWeight="SemiBold" FontSize="13" Margin="2,10,2,0"
                       TextTrimming="CharacterEllipsis" />
            <TextBlock Text="{Binding ArtistName, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Style="{StaticResource Muted}" FontSize="11" Margin="2,3,2,0"
                       TextTrimming="CharacterEllipsis" />
        </StackPanel>
    </Button>
</UserControl>
