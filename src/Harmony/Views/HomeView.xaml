<UserControl x:Class="Harmony.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Harmony.ViewModels"
             xmlns:views="clr-namespace:Harmony.Views"
             xmlns:models="clr-namespace:Harmony.Models"
             xmlns:img="clr-namespace:Harmony.Helpers">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="False">
        <StackPanel Margin="{StaticResource PagePadding}">

            <!-- Dashboard header -->
            <Grid Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock FontSize="34" FontWeight="Bold">
                        <Run Text="{Binding Greeting, Mode=OneWay}" />
                        <Run Text=", " />
                        <Run Text="{Binding UserDisplayName, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock Text="{Binding GreetingSubtitle}" Style="{StaticResource Muted}" FontSize="14" Margin="0,6,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Style="{StaticResource IconButton}" Width="40" Height="40" ToolTip="Search"
                            Command="{Binding OpenSearchCommand}">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource IconSearch}" Width="18" Height="18" />
                    </Button>
                    <Button Style="{StaticResource IconButton}" Width="40" Height="40" ToolTip="Settings" Margin="6,0,0,0"
                            Command="{Binding OpenSettingsCommand}">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource IconSettings}" Width="18" Height="18" />
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Home tabs -->
            <ItemsControl ItemsSource="{Binding HomeTabs}" Margin="0,0,0,16">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:HomeTabChip}">
                        <Button Content="{Binding Label}"
                                Command="{Binding DataContext.SelectTabCommand, RelativeSource={RelativeSource AncestorType={x:Type views:HomeView}}}"
                                CommandParameter="{Binding}" Margin="0,0,8,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource FilterChip}">
                                    <Style.Triggers>
                                        <DataTrigger Value="True">
                                            <DataTrigger.Binding>
                                                <MultiBinding Converter="{StaticResource FilterChipSelected}">
                                                    <Binding Path="Id" />
                                                    <Binding Path="DataContext.SelectedTab"
                                                             RelativeSource="{RelativeSource AncestorType={x:Type views:HomeView}}" />
                                                </MultiBinding>
                                            </DataTrigger.Binding>
                                            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                            <Setter Property="Foreground" Value="Black" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Discover: shortcuts (no track grid) -->
            <StackPanel Visibility="{Binding IsDiscoverTab, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,24">
                <TextBlock Text="{Binding DiscoverTitle}" FontSize="32" FontWeight="Bold" Margin="0,0,0,6" />
                <TextBlock Text="{Binding BrowseSubtitle}" Style="{StaticResource Muted}" FontSize="14" Margin="0,0,0,16" />
                <ItemsControl ItemsSource="{Binding BrowseShortcuts}" Margin="0,0,0,8"
                              Visibility="{Binding HasBrowseShortcuts, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:HomeQuickTile}">
                            <Button Style="{StaticResource GlassQuickCard}" Margin="0,0,12,12"
                                    Command="{Binding DataContext.OpenBrowseShortcutCommand, RelativeSource={RelativeSource AncestorType={x:Type views:HomeView}}}"
                                    CommandParameter="{Binding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" Background="#14FFFFFF">
                                        <Grid>
                                            <Path Data="{StaticResource IconHeartFilled}" Fill="White" Stretch="Uniform" Width="20" Height="20"
                                                  Visibility="{Binding IsLikedSongs, Converter={StaticResource BoolToVisibility}}" />
                                            <Path Data="{StaticResource IconHistory}" Fill="{StaticResource TextSecondaryBrush}"
                                                  Stretch="Uniform" Width="20" Height="20"
                                                  Visibility="{Binding IsRecent, Converter={StaticResource BoolToVisibility}}" />
                                            <Path Data="{StaticResource IconRadio}" Fill="{StaticResource TextSecondaryBrush}"
                                                  Stretch="Uniform" Width="20" Height="20"
                                                  Visibility="{Binding IsRadio, Converter={StaticResource BoolToVisibility}}" />
                                            <Path Data="{StaticResource IconLibrary}" Fill="{StaticResource TextSecondaryBrush}"
                                                  Stretch="Uniform" Width="20" Height="20"
                                                  Visibility="{Binding IsLibrary, Converter={StaticResource BoolToVisibility}}" />
                                            <Path Data="{StaticResource IconAlbum}" Fill="{StaticResource TextSecondaryBrush}"
                                                  Stretch="Uniform" Width="20" Height="20"
                                                  Visibility="{Binding IsAlbums, Converter={StaticResource BoolToVisibility}}" />
                                            <Path Data="{StaticResource IconPlaylist}" Fill="{StaticResource TextSecondaryBrush}"
                                                  Stretch="Uniform" Width="20" Height="20"
                                                  Visibility="{Binding IsPlaylist, Converter={StaticResource BoolToVisibility}}" />
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14" />
                                        <TextBlock Text="{Binding Subtitle}" Style="{StaticResource Muted}" FontSize="11" Margin="0,2,0,0"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="{Binding RecommendedPlaylistsLabel}" FontSize="22" FontWeight="Bold" Margin="0,12,0,12"
                           Visibility="{Binding HasRecommendedPlaylists, Converter={StaticResource BoolToVisibility}}" />
                <views:HorizontalScrollRow ItemsSource="{Binding RecommendedPlaylists}"
                                           Visibility="{Binding HasRecommendedPlaylists, Converter={StaticResource BoolToVisibility}}">
                    <views:HorizontalScrollRow.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:HomePlaylistCard}">
                            <Button Width="160" Height="200" Margin="0,0,14,0" Cursor="Hand"
                                    Command="{Binding DataContext.SelectPlaylistFromHomeCommand, RelativeSource={RelativeSource AncestorType={x:Type views:HomeView}}}"
                                    CommandParameter="{Binding}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <StackPanel>
                                            <Border Width="160" Height="160" CornerRadius="8" ClipToBounds="True"
                                                    Background="#FF243838">
                                                <Grid>
                                                    <Image Source="{Binding SingleCoverUrl}" Stretch="UniformToFill"
                                                           Visibility="{Binding HasSingleCover, Converter={StaticResource BoolToVisibility}}" />
                                                    <Grid Visibility="{Binding HasMosaic, Converter={StaticResource BoolToVisibility}}">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition />
                                                            <RowDefinition />
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition />
                                                            <ColumnDefinition />
                                                        </Grid.ColumnDefinitions>
                                                        <Image Grid.Row="0" Grid.Column="0" Source="{Binding Thumbnails[0]}" Stretch="UniformToFill" />
                                                        <Image Grid.Row="0" Grid.Column="1" Source="{Binding Thumbnails[1]}" Stretch="UniformToFill" />
                                                        <Image Grid.Row="1" Grid.Column="0" Source="{Binding Thumbnails[2]}" Stretch="UniformToFill" />
                                                        <Image Grid.Row="1" Grid.Column="1" Source="{Binding Thumbnails[3]}" Stretch="UniformToFill" />
                                                    </Grid>
                                                    <Path Data="{StaticResource IconPlaylist}" Fill="White" Stretch="Uniform"
                                                          Width="48" Height="48" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          Visibility="{Binding HasDefaultCover, Converter={StaticResource BoolToVisibility}}" />
                                                </Grid>
                                            </Border>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Margin="0,8,0,0" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding TrackCount, Converter={StaticResource TrackCountLabel}}"
                                                       Style="{StaticResource RzMeta}" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </views:HorizontalScrollRow.ItemTemplate>
                </views:HorizontalScrollRow>
            </StackPanel>

            <!-- Daily mix -->
            <Border Style="{StaticResource GlassPanel}" Margin="0,0,0,20" Padding="20"
                    Visibility="{Binding HasDailyMix, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding DailyMix.Title}" FontWeight="Bold" FontSize="20" />
                        <TextBlock Text="{Binding DailyMix.Subtitle}" Style="{StaticResource Muted}" Margin="0,4,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1" Style="{StaticResource PlayButton}"
                            Command="{Binding PlayMixCommand}" CommandParameter="{Binding DailyMix}">
                        <Path Data="{StaticResource IconPlay}" Fill="Black" Stretch="Uniform" Width="18" Height="18" />
                    </Button>
                </Grid>
            </Border>

            <!-- Featured hero (compact — height follows content, not image pixels) -->
            <Border CornerRadius="16" Padding="12,10" Margin="0,0,0,20" ClipToBounds="True"
                    BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1"
                    Visibility="{Binding HasFeatured, Converter={StaticResource BoolToVisibility}}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1AFFFFFF" Offset="0" />
                        <GradientStop Color="#0DFFFFFF" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="72" Height="72" CornerRadius="10"
                            BorderBrush="#33FFFFFF" BorderThickness="1" ClipToBounds="True"
                            VerticalAlignment="Center" Margin="0,0,14,0">
                        <Grid>
                            <Path Data="{StaticResource IconNote}" Fill="{StaticResource TextMutedBrush}"
                                  Stretch="Uniform" Width="24" Height="24" />
                            <Image img:ImageLoader.SourceUrl="{Binding FeaturedTrack.ThumbnailUrl}"
                                   img:ImageLoader.DecodeWidth="96" Stretch="UniformToFill" />
                        </Grid>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding FeaturedTodayLabel}" Style="{StaticResource Muted}" FontSize="10"
                                   FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,2" />
                        <TextBlock Text="{Binding FeaturedTrack.Title}" FontSize="18" FontWeight="Bold"
                                   TextWrapping="Wrap" MaxWidth="380" LineHeight="22" />
                        <TextBlock Text="{Binding FeaturedTrack.ArtistName}" Style="{StaticResource Subtle}"
                                   FontSize="12" Margin="0,1,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                        <Button Style="{StaticResource PillButton}" Command="{Binding PlayFeaturedCommand}" Padding="14,7">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconPlay}" Fill="Black" Stretch="Uniform" Width="11" Height="11" />
                                <TextBlock Text="{Binding PlayNowLabel}" FontWeight="SemiBold" FontSize="12"
                                           Margin="7,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource OutlineButton}" Margin="6,0,0,0"
                                Command="{Binding ShuffleFeaturedCommand}" Content="{Binding ShuffleLabel}"
                                Padding="12,6" FontSize="12" />
                        <views:FavoriteHeart Command="{Binding LikeCommand}" Track="{Binding FeaturedTrack}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Quick access -->
            <TextBlock Text="{Binding QuickAccessLabel}" Style="{StaticResource SectionTitle}" FontSize="20" />
            <ItemsControl ItemsSource="{Binding QuickTiles}" Margin="0,0,0,28">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:HomeQuickTile}">
                        <Button Style="{StaticResource GlassQuickCard}"
                                Command="{Binding DataContext.OpenQuickTileCommand, RelativeSource={RelativeSource AncestorType={x:Type views:HomeView}}}"
                                CommandParameter="{Binding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#14FFFFFF" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLikedSongs}" Value="True">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#FF7C3AED" Offset="0" />
                                                                <GradientStop Color="#FF22C55E" Offset="1" />
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Path Data="{StaticResource IconHeartFilled}" Fill="White" Stretch="Uniform" Width="20" Height="20"
                                              Visibility="{Binding IsLikedSongs, Converter={StaticResource BoolToVisibility}}" />
                                        <Path Data="{StaticResource IconHistory}" Fill="{StaticResource TextSecondaryBrush}"
                                              Stretch="Uniform" Width="20" Height="20"
                                              Visibility="{Binding IsRecent, Converter={StaticResource BoolToVisibility}}" />
                                        <Path Data="{StaticResource IconLibrary}" Fill="{StaticResource TextSecondaryBrush}"
                                              Stretch="Uniform" Width="20" Height="20"
                                              Visibility="{Binding IsLibrary, Converter={StaticResource BoolToVisibility}}" />
                                        <Path Data="{StaticResource IconAlbum}" Fill="{StaticResource TextSecondaryBrush}"
                                              Stretch="Uniform" Width="20" Height="20"
                                              Visibility="{Binding IsAlbums, Converter={StaticResource BoolToVisibility}}" />
                                        <Path Data="{StaticResource IconPlaylist}" Fill="{StaticResource TextSecondaryBrush}"
                                              Stretch="Uniform" Width="20" Height="20"
                                              Visibility="{Binding IsPlaylist, Converter={StaticResource BoolToVisibility}}" />
                                    </Grid>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock Text="{Binding Subtitle}" Style="{StaticResource Muted}" FontSize="11" Margin="0,2,0,0" />
                                </StackPanel>
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Continue listening -->
            <Border Style="{StaticResource GlassPanel}" Margin="0,0,0,28" Padding="20"
                    Visibility="{Binding HasContinue, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="64" Height="64" CornerRadius="12" ClipToBounds="True"
                            BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1">
                        <Grid>
                            <Path Data="{StaticResource IconNote}" Fill="{StaticResource TextMutedBrush}" Stretch="Uniform" Width="28" Height="28" />
                            <Image img:ImageLoader.SourceUrl="{Binding ContinueTrack.ThumbnailUrl}"
                                   img:ImageLoader.DecodeWidth="96" Stretch="UniformToFill" />
                        </Grid>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="16,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ContinueListeningLabel}" Style="{StaticResource Muted}" FontSize="11" FontWeight="Bold" />
                        <TextBlock Text="{Binding ContinueTrack.Title}" FontWeight="SemiBold" FontSize="16" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding ContinueTrack.ArtistName}" Style="{StaticResource Subtle}" />
                        <Border Height="4" CornerRadius="2" Background="#14FFFFFF" Margin="0,10,0,0" MaxWidth="320" HorizontalAlignment="Left">
                            <Border Height="4" CornerRadius="2" HorizontalAlignment="Left"
                                    Background="{StaticResource AccentBrush}"
                                    Width="{Binding ContinueProgress, Converter={StaticResource VolumeToWidth}, ConverterParameter=320}" />
                        </Border>
                    </StackPanel>
                    <Button Grid.Column="2" Style="{StaticResource PlayButton}" VerticalAlignment="Center"
                            Command="{Binding ContinueListeningCommand}">
                        <Path Data="{StaticResource IconPlay}" Fill="Black" Stretch="Uniform" Width="18" Height="18" />
                    </Button>
                </Grid>
            </Border>

            <!-- Recently played cards -->
            <TextBlock Text="{Binding RecentlyPlayedLabel}" Style="{StaticResource SectionTitle}" FontSize="20"
                       Visibility="{Binding HasRecentCards, Converter={StaticResource BoolToVisibility}}" />
            <views:HorizontalScrollRow ItemsSource="{Binding RecentCards}" Margin="0,0,0,28"
                                       Visibility="{Binding HasRecentCards, Converter={StaticResource BoolToVisibility}}">
                <views:HorizontalScrollRow.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource GlassTrackCard}"
                                Command="{Binding DataContext.PlaySectionTrackCommand, RelativeSource={RelativeSource AncestorType={x:Type views:HomeView}}}"
                                CommandParameter="{Binding}">
                            <StackPanel>
                                <Border Height="120" CornerRadius="18,18,0,0" ClipToBounds="True">
                                    <Grid>
                                        <Path Data="{StaticResource IconNote}" Fill="{StaticResource TextMutedBrush}" Stretch="Uniform" Width="36" Height="36" />
                                        <Image img:ImageLoader.SourceUrl="{Binding ThumbnailUrl}"
                                               img:ImageLoader.DecodeWidth="128" Stretch="UniformToFill" />
                                        <Border Background="#66000000" Opacity="0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                                            <Setter Property="Opacity" Value="1" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Path Data="{StaticResource IconPlay}" Fill="White" Stretch="Uniform" Width="32" Height="32"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                </Border>
                                <StackPanel Margin="12,10,12,12">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding ArtistName}" Style="{StaticResource Muted}" FontSize="11" Margin="0,2,0,0" />
                                </StackPanel>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </views:HorizontalScrollRow.ItemTemplate>
            </views:HorizontalScrollRow>

            <!-- Recommendations -->
            <TextBlock Text="{Binding MadeForYouLabel}" Style="{StaticResource SectionTitle}" FontSize="20"
                       Visibility="{Binding HasRecommendations, Converter={StaticResource BoolToVisibility}}" />
            <views:HorizontalScrollRow ItemsSource="{Binding RecommendationMixes}" Margin="0,0,0,28"
                                       Visibility="{Binding HasRecommendations, Converter={StaticResource BoolToVisibility}}">
                <views:HorizontalScrollRow.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:HomeMixCard}">
                        <Button Width="220" Height="120" Margin="0,0,14,0" Cursor="Hand" Padding="0"
                                Command="{Binding DataContext.PlayMixCommand, RelativeSource={RelativeSource AncestorType={x:Type views:HomeView}}}"
                                CommandParameter="{Binding}"
                                Background="Transparent" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="20" BorderThickness="1"
                                            BorderBrush="{StaticResource GlassBorderBrush}" ClipToBounds="True"
                                            Background="{StaticResource GlassFillBrush}">
                                        <Grid>
                                            <Image img:ImageLoader.SourceUrl="{Binding SeedTrack.ThumbnailUrl}"
                                                   img:ImageLoader.DecodeWidth="200" Stretch="UniformToFill" Opacity="0.4" />
                                            <Rectangle>
                                                <Rectangle.Fill>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#00000000" Offset="0" />
                                                        <GradientStop Color="#CC09090B" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Rectangle.Fill>
                                            </Rectangle>
                                            <StackPanel Margin="18" VerticalAlignment="Bottom">
                                                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="18" />
                                                <TextBlock Text="{Binding Subtitle}" Style="{StaticResource Muted}" FontSize="11" Margin="0,4,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.95" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DataTemplate>
                </views:HorizontalScrollRow.ItemTemplate>
            </views:HorizontalScrollRow>

            <!-- Genre picks -->
            <ItemsControl ItemsSource="{Binding GenreSections}"
                          Visibility="{Binding HasGenreSections, Converter={StaticResource BoolToVisibility}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:HomeTrackSection}">
                        <Border Style="{StaticResource GlassPanel}" Padding="12,10" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitle}" FontSize="20" />
                                <ListBox ItemsSource="{Binding Tracks}" Style="{StaticResource ActiveTrackListStyle}" Margin="0,8,0,0"
                                         ScrollViewer.VerticalScrollBarVisibility="Disabled" ScrollViewer.CanContentScroll="False">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="1" Grid.ColumnSpan="3"
                                                        Style="{StaticResource TrackRowHitButton}"
                                                        Command="{Binding DataContext.PlaySectionTrackCommand, RelativeSource={RelativeSource AncestorType={x:Type views:HomeView}}}"
                                                        CommandParameter="{Binding}" />
                                                <Button Grid.Column="0" Style="{StaticResource IconButton}"
                                                        Command="{Binding DataContext.PlaySectionTrackCommand, RelativeSource={RelativeSource AncestorType={x:Type views:HomeView}}}"
                                                        CommandParameter="{Binding}">
                                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource IconPlay}" />
                                                </Button>
                                                <Border Grid.Column="1" Width="44" Height="44" CornerRadius="4" Margin="6,0,0,0"
                                                        Background="{StaticResource SurfaceHoverBrush}">
                                                    <Grid>
                                                        <Path Data="{StaticResource IconNote}" Fill="{StaticResource TextSecondaryBrush}"
                                                              Stretch="Uniform" Width="20" Height="20" />
                                                        <Image img:ImageLoader.SourceUrl="{Binding ThumbnailUrl}"
                                                               img:ImageLoader.DecodeWidth="128" Stretch="UniformToFill" />
                                                    </Grid>
                                                </Border>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="12,0">
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14" />
                                                    <TextBlock Text="{Binding ArtistName}" Style="{StaticResource Subtle}" />
                                                </StackPanel>
                                                <Button Grid.Column="3" Style="{StaticResource IconButton}"
                                                        Command="{Binding DataContext.FindSimilarCommand, RelativeSource={RelativeSource AncestorType={x:Type views:HomeView}}}"
                                                        CommandParameter="{Binding}" ToolTip="Find similar">
                                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource IconSearch}" Width="14" Height="14" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Albums (grouped rows) -->
            <ItemsControl ItemsSource="{Binding AlbumSections}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:HomeAlbumSection}">
                        <Border Style="{StaticResource GlassPanel}" Padding="12,10" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitle}" FontSize="20" />
                                <views:HorizontalScrollRow ItemsSource="{Binding Albums}" Margin="0,8,0,0">
                                    <views:HorizontalScrollRow.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:HomeAlbumCard}">
                                            <views:AlbumCard
                                                PlayCommand="{Binding DataContext.OpenAlbumCommand, RelativeSource={RelativeSource AncestorType={x:Type views:HomeView}}}"
                                                CommandParameter="{Binding}"
                                                Title="{Binding Title}"
                                                ArtistName="{Binding ArtistName}"
                                                ThumbnailUrl="{Binding ThumbnailUrl}" />
                                        </DataTemplate>
                                    </views:HorizontalScrollRow.ItemTemplate>
                                </views:HorizontalScrollRow>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Top chart (grouped) -->
            <ItemsControl ItemsSource="{Binding ChartSections}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:HomeTrackSection}">
                        <Border Style="{StaticResource GlassPanel}" Padding="12,10" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitle}" FontSize="20" />
                                <ListBox ItemsSource="{Binding Tracks}" Style="{StaticResource ActiveTrackListStyle}" Margin="0,8,0,0"
                                         ScrollViewer.VerticalScrollBarVisibility="Disabled" ScrollViewer.CanContentScroll="False">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="1" Grid.ColumnSpan="2"
                                                        Style="{StaticResource TrackRowHitButton}"
                                                        Command="{Binding DataContext.PlaySectionTrackCommand, RelativeSource={RelativeSource AncestorType={x:Type views:HomeView}}}"
                                                        CommandParameter="{Binding}" />
                                                <Button Grid.Column="0" Style="{StaticResource IconButton}"
                                                        Command="{Binding DataContext.PlaySectionTrackCommand, RelativeSource={RelativeSource AncestorType={x:Type views:HomeView}}}"
                                                        CommandParameter="{Binding}">
                                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource IconPlay}" />
                                                </Button>
                                                <Border Grid.Column="1" Width="44" Height="44" CornerRadius="4" Margin="6,0,0,0"
                                                        Background="{StaticResource SurfaceHoverBrush}">
                                                    <Grid>
                                                        <Path Data="{StaticResource IconNote}" Fill="{StaticResource TextSecondaryBrush}"
                                                              Stretch="Uniform" Width="20" Height="20" />
                                                        <Image img:ImageLoader.SourceUrl="{Binding ThumbnailUrl}"
                                               img:ImageLoader.DecodeWidth="128" Stretch="UniformToFill" />
                                                    </Grid>
                                                </Border>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="12,0">
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14" />
                                                    <TextBlock Style="{StaticResource Subtle}">
                                                        <Run Text="{Binding ArtistName, Mode=OneWay}" />
                                                        <Run Text=" • " />
                                                        <Run Text="{Binding AlbumName, Mode=OneWay}" />
                                                    </TextBlock>
                                                </StackPanel>
                                                <StackPanel Grid.Column="3" Orientation="Horizontal">
                                                    <views:FavoriteHeart Grid.Column="4"
                                                        Track="{Binding}"
                                                        Command="{Binding DataContext.LikeCommand, RelativeSource={RelativeSource AncestorType={x:Type views:HomeView}}}" />
                                                    <Button Style="{StaticResource IconButton}"
                                                            Command="{Binding DataContext.AddToLibraryCommand, RelativeSource={RelativeSource AncestorType={x:Type views:HomeView}}}"
                                                            CommandParameter="{Binding}">
                                                        <Path Style="{StaticResource IconPath}" Data="{StaticResource IconAdd}" />
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Favorites (grouped) -->
            <ItemsControl ItemsSource="{Binding FavoriteSections}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:HomeTrackSection}">
                        <Border Style="{StaticResource GlassPanel}" Padding="12,10" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitle}" FontSize="20" />
                                <ListBox ItemsSource="{Binding Tracks}" Style="{StaticResource ActiveTrackListStyle}" Margin="0,8,0,0"
                                         ScrollViewer.VerticalScrollBarVisibility="Disabled" ScrollViewer.CanContentScroll="False">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="1" Grid.ColumnSpan="3"
                                                        Style="{StaticResource TrackRowHitButton}"
                                                        Command="{Binding DataContext.PlaySectionTrackCommand, RelativeSource={RelativeSource AncestorType={x:Type views:HomeView}}}"
                                                        CommandParameter="{Binding}" />
                                                <Button Grid.Column="0" Style="{StaticResource IconButton}"
                                                        Command="{Binding DataContext.PlaySectionTrackCommand, RelativeSource={RelativeSource AncestorType={x:Type views:HomeView}}}"
                                                        CommandParameter="{Binding}">
                                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource IconPlay}" />
                                                </Button>
                                                <Border Grid.Column="1" Width="44" Height="44" CornerRadius="4" Margin="6,0,0,0"
                                                        Background="{StaticResource SurfaceHoverBrush}">
                                                    <Grid>
                                                        <Path Data="{StaticResource IconNote}" Fill="{StaticResource TextSecondaryBrush}"
                                                              Stretch="Uniform" Width="20" Height="20" />
                                                        <Image img:ImageLoader.SourceUrl="{Binding ThumbnailUrl}"
                                               img:ImageLoader.DecodeWidth="128" Stretch="UniformToFill" />
                                                    </Grid>
                                                </Border>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="12,0">
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14" />
                                                    <TextBlock Text="{Binding ArtistName}" Style="{StaticResource Subtle}" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="3" Text="{Binding DurationDisplay}" Style="{StaticResource Subtle}"
                                                           VerticalAlignment="Center" Margin="8,0" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="{Binding Loc.CommonLoading}" Style="{StaticResource Subtle}"
                       HorizontalAlignment="Center" Margin="0,20"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" />
            <TextBlock Text="{Binding LoadingMoreLabel}" Style="{StaticResource Subtle}"
                       HorizontalAlignment="Center" Margin="0,0,0,12"
                       Visibility="{Binding IsLoadingMore, Converter={StaticResource BoolToVisibility}}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
