<UserControl x:Class="Harmony.Views.AmbientBackground"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsHitTestVisible="False"
             Focusable="False">
    <!-- Static gradients only — blur + infinite animations caused lag while dragging the window -->
    <Grid ClipToBounds="True">
        <Ellipse Width="520" Height="520" HorizontalAlignment="Left" VerticalAlignment="Top"
                 Margin="-80,-60,0,0" Opacity="0.28">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#AA8B5CF6" Offset="0" />
                    <GradientStop Color="#008B5CF6" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <Ellipse Width="480" Height="480" HorizontalAlignment="Right" VerticalAlignment="Top"
                 Margin="0,40,-100,0" Opacity="0.22">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#AA38BDF8" Offset="0" />
                    <GradientStop Color="#0038BDF8" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <Ellipse Width="400" Height="400" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                 Margin="0,0,0,-120" Opacity="0.18">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#997C3AED" Offset="0" />
                    <GradientStop Color="#007C3AED" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
    </Grid>
</UserControl>
