<UserControl x:Class="Harmony.Views.CollectionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Harmony.ViewModels"
             xmlns:views="clr-namespace:Harmony.Views"
             xmlns:cmp="clr-namespace:Harmony.Components"
             xmlns:models="clr-namespace:Harmony.Models">

    <Grid MinHeight="320" VerticalAlignment="Stretch">
        <!-- ===== Playlist browse (grid) ===== -->
        <Grid Margin="{StaticResource PagePadding}" Visibility="{Binding ShowPlaylistBrowse, Converter={StaticResource BoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="{Binding Loc.NavPlaylists}" Style="{StaticResource RzPageTitle}" FontSize="32" VerticalAlignment="Center" />
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,0,0,14" Orientation="Horizontal"
                        Visibility="Collapsed" />

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <cmp:EmptyState Title="{Binding CreateFirstPlaylistTitle}"
                                    Description="{Binding CreateFirstPlaylistDesc}"
                                    ActionText="{Binding Loc.CommonCreate}"
                                    ActionCommand="{Binding OpenCreatePlaylistDialogCommand}"
                                    IconData="{StaticResource IconPlaylist}"
                                    HorizontalAlignment="Left" Margin="0,8,0,0"
                                    Visibility="{Binding IsPlaylistsEmpty, Converter={StaticResource BoolToVisibility}}" />

                    <WrapPanel Visibility="{Binding IsPlaylistsEmpty, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}">
                        <Button Style="{StaticResource RzNewPlaylistCard}"
                                Command="{Binding OpenCreatePlaylistDialogCommand}" />
                        <ItemsControl ItemsSource="{Binding Playlists}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <cmp:PlaylistCard Title="{Binding Name}"
                                                      Subtitle="{Binding TrackCount, Converter={StaticResource TrackCountLabel}}"
                                                      Command="{Binding DataContext.SelectPlaylistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </WrapPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ===== Spotify-style playlist detail ===== -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" VerticalAlignment="Stretch"
                      Visibility="{Binding ShowPlaylistDetail, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
                <Border MinHeight="280" Padding="28,24,28,24">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#668B5CF6" Offset="0" />
                            <GradientStop Color="#33101820" Offset="0.5" />
                            <GradientStop Color="#FF07080D" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0" Style="{StaticResource OutlineButton}" HorizontalAlignment="Left"
                                Content="{Binding BackToPlaylistsLabel}" Command="{Binding GoBackFromPlaylistCommand}"
                                Padding="12,6" Margin="0,0,0,20" />

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="232" Height="232" CornerRadius="8" ClipToBounds="True"
                                    Margin="0,0,28,0" Background="#FF282828">
                                <Grid>
                                    <Image Source="{Binding PrimaryCoverUrl}" Stretch="UniformToFill"
                                           Visibility="{Binding ShowSingleCover, Converter={StaticResource BoolToVisibility}}" />
                                    <Grid Visibility="{Binding ShowMosaicCover, Converter={StaticResource BoolToVisibility}}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition />
                                            <RowDefinition />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>
                                        <Image Grid.Row="0" Grid.Column="0" Source="{Binding CoverMosaicTracks[0].ThumbnailUrl}" Stretch="UniformToFill" />
                                        <Image Grid.Row="0" Grid.Column="1" Source="{Binding CoverMosaicTracks[1].ThumbnailUrl}" Stretch="UniformToFill" />
                                        <Image Grid.Row="1" Grid.Column="0" Source="{Binding CoverMosaicTracks[2].ThumbnailUrl}" Stretch="UniformToFill" />
                                        <Image Grid.Row="1" Grid.Column="1" Source="{Binding CoverMosaicTracks[3].ThumbnailUrl}" Stretch="UniformToFill" />
                                    </Grid>
                                    <Path Data="{StaticResource IconPlaylist}" Fill="#88FFFFFF"
                                          Stretch="Uniform" Width="72" Height="72"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Visibility="{Binding ShowDefaultCover, Converter={StaticResource BoolToVisibility}}" />
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                                <TextBlock Text="{Binding KindLabel}" FontSize="12" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Opacity="0.85" Margin="0,0,0,8" />
                                <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="58" FontWeight="Bold" Background="Transparent" BorderThickness="0"
                                         Padding="0" Margin="0,0,0,12" />
                                <TextBlock Text="{Binding OwnerMetaLine}" FontSize="14" Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="2">
                        <StackPanel Orientation="Horizontal" Margin="0,28,0,0">
                            <Button Style="{StaticResource PlayButton}" Command="{Binding PlayAllCommand}" Margin="0,0,12,0">
                                <Path Data="{StaticResource IconPlay}" Fill="White" Stretch="Uniform" Width="18" Height="18" />
                            </Button>
                            <Button Style="{StaticResource OutlineButton}" Content="{Binding ShuffleLabel}"
                                    Command="{Binding ShuffleAllCommand}" Padding="16,10" Margin="0,0,8,0" />
                            <Button Style="{StaticResource GhostButton}" Command="{Binding ToggleAddPanelCommand}"
                                    ToolTip="{Binding FindSongsTitle}" Padding="12,10">
                                <Path Data="{StaticResource IconAdd}" Fill="{StaticResource TextSecondaryBrush}"
                                      Stretch="Uniform" Width="16" Height="16" />
                            </Button>
                            <Button Style="{StaticResource GhostButton}" Content="{Binding Loc.CommonDelete}"
                                    Command="{Binding DeleteCommand}" Margin="8,0,0,0" Padding="14,10" />
                        </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Track table -->
                <Grid Margin="32,8,32,32">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="8,0,8,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="48" />
                            <ColumnDefinition Width="2.2*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="60" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="2" Text="{Binding SortTitleLabel}" Style="{StaticResource Muted}" FontSize="11" FontWeight="Bold" />
                        <TextBlock Grid.Column="3" Text="{Binding AlbumColumnLabel}" Style="{StaticResource Muted}" FontSize="11" FontWeight="Bold" />
                        <TextBlock Grid.Column="4" Text="{Binding DateAddedColumnLabel}" Style="{StaticResource Muted}" FontSize="11" FontWeight="Bold" />
                        <Path Grid.Column="5" Data="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.2 3.2.8-1.3-4.5-2.7V7z"
                              Fill="{StaticResource TextMutedBrush}" Stretch="Uniform" Width="14" Height="14" HorizontalAlignment="Right" />
                    </Grid>

                    <ItemsControl Grid.Row="1" ItemsSource="{Binding FilteredTrackRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:CollectionTrackRow}">
                                <Border x:Name="RowBorder" MinHeight="52" Margin="0,1" CornerRadius="6"
                                        Background="Transparent" Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#1AFFFFFF" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="52" />
                                            <ColumnDefinition Width="2.2*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0" Grid.ColumnSpan="6" Style="{StaticResource TrackRowHitButton}"
                                                Command="{Binding DataContext.PlayCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Track}" />

                                        <Grid Grid.ColumnSpan="6" Panel.ZIndex="1" IsHitTestVisible="False">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40" />
                                                <ColumnDefinition Width="52" />
                                                <ColumnDefinition Width="2.2*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="100" />
                                            </Grid.ColumnDefinitions>

                                            <Grid Grid.Column="0" Width="40" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Index}" FontSize="13"
                                                           VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource Muted}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsMouseOver, ElementName=RowBorder}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                                <DataTrigger Value="True">
                                                                    <DataTrigger.Binding>
                                                                        <MultiBinding Converter="{StaticResource IsSameTrack}">
                                                                            <Binding Path="Track" />
                                                                            <Binding Path="DataContext.Player.CurrentTrack, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                                        </MultiBinding>
                                                                    </DataTrigger.Binding>
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <Path Data="{StaticResource IconPlay}" Stretch="Uniform" Width="14" Height="14"
                                                      Fill="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" Visibility="Collapsed">
                                                    <Path.Style>
                                                        <Style TargetType="Path">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsMouseOver, ElementName=RowBorder}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Path.Style>
                                                </Path>
                                                <Path Data="{StaticResource IconVolume}" Stretch="Uniform" Width="14" Height="14"
                                                      Fill="{StaticResource AccentBrush}" HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" Visibility="Collapsed">
                                                    <Path.Style>
                                                        <Style TargetType="Path">
                                                            <Style.Triggers>
                                                                <DataTrigger Value="True">
                                                                    <DataTrigger.Binding>
                                                                        <MultiBinding Converter="{StaticResource IsSameTrack}">
                                                                            <Binding Path="Track" />
                                                                            <Binding Path="DataContext.Player.CurrentTrack, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                                        </MultiBinding>
                                                                    </DataTrigger.Binding>
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Path.Style>
                                                </Path>
                                            </Grid>

                                            <Border Grid.Column="1" Width="44" Height="44" CornerRadius="4" ClipToBounds="True">
                                                <Grid>
                                                    <Path Data="{StaticResource IconNote}" Fill="{StaticResource TextMutedBrush}"
                                                          Stretch="Uniform" Width="16" Height="16" />
                                                    <Image Source="{Binding Track.ThumbnailUrl}" Stretch="UniformToFill" />
                                                    <Border Background="#99000000" Visibility="Collapsed">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsMouseOver, ElementName=RowBorder}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Path Data="{StaticResource IconPlay}" Fill="White" Stretch="Uniform"
                                                              Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="4,0,8,0">
                                                <TextBlock Text="{Binding Track.Title}" FontWeight="SemiBold" FontSize="14" />
                                                <TextBlock Text="{Binding Track.ArtistName}" Style="{StaticResource Muted}" FontSize="12" />
                                            </StackPanel>

                                            <Border Grid.Column="3" Background="#FF333333" CornerRadius="4" Padding="10,4"
                                                    VerticalAlignment="Center" Margin="0,0,12,0"
                                                    Visibility="{Binding Track.AlbumName, Converter={StaticResource NullToVisibility}}">
                                                <TextBlock Text="{Binding Track.AlbumName}"
                                                           FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxWidth="180" />
                                            </Border>

                                            <TextBlock Grid.Column="4" Text="{Binding AddedAtDisplay, FallbackValue=—}"
                                                       Style="{StaticResource Muted}" FontSize="13" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />

                                            <TextBlock Grid.Column="5" Text="{Binding Track.DurationDisplay}"
                                                       FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource Muted}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsMouseOver, ElementName=RowBorder}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>

                                        <StackPanel Grid.Column="5" Grid.ColumnSpan="1" Orientation="Horizontal"
                                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                                    Panel.ZIndex="2" Visibility="Collapsed">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=RowBorder}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <Button Style="{StaticResource IconButton}" Width="32" Height="32" Margin="0,0,4,0"
                                                    Command="{Binding DataContext.AddTrackElsewhereCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Track}" ToolTip="{Binding DataContext.AddToPlaylistTip, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                <Path Data="{StaticResource IconAdd}" Fill="{StaticResource TextSecondaryBrush}"
                                                      Stretch="Uniform" Width="18" Height="18" />
                                            </Button>
                                            <Button Style="{StaticResource IconButton}" Width="32" Height="32"
                                                    Click="OpenTrackMenu_Click">
                                                <Path Data="{StaticResource IconMore}" Fill="{StaticResource TextSecondaryBrush}"
                                                      Stretch="Uniform" Width="18" Height="18" />
                                                <Button.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="{Binding DataContext.RemoveFromPlaylistTip, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  Command="{Binding DataContext.RemoveTrackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  CommandParameter="{Binding Track}" />
                                                    </ContextMenu>
                                                </Button.ContextMenu>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- ===== Albums mode (unchanged layout) ===== -->
        <Grid Margin="28,24,28,24" Visibility="{Binding IsAlbumsMode, Converter={StaticResource BoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Loc.NavAlbums}" Style="{StaticResource Heading}" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource OutlineButton}" Content="{Binding TabPlaylistsLabel}"
                            Command="{Binding SelectKindCommand}" CommandParameter="{x:Static vm:CollectionKind.Playlists}" Margin="0,0,8,0" />
                    <Button Style="{StaticResource OutlineButton}" Content="{Binding Loc.CommonImport}"
                            Command="{Binding ImportFromPcCommand}" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,18">
                <Button Style="{StaticResource OutlineButton}" Content="{Binding Loc.CommonImport}"
                        Command="{Binding ImportFromPcCommand}" />
            </StackPanel>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource GlassPanel}" Margin="0,0,20,0" Padding="16">
                    <StackPanel>
                        <TextBlock Text="{Binding CreateNewLabel}" FontWeight="Bold" Margin="0,0,0,10" />
                        <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                        <Button Style="{StaticResource PillButton}" Content="{Binding Loc.CommonCreate}" Command="{Binding CreateCommand}" />
                        <ListBox ItemsSource="{Binding UserAlbums}" SelectedItem="{Binding SelectedAlbum, Mode=TwoWay}"
                                 Style="{StaticResource TrackListBox}" Margin="0,16,0,0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <Grid Grid.Column="1" Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibility}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource GlassHeroCard}" Margin="0,0,0,16" Padding="24">
                        <StackPanel>
                            <TextBlock Text="{Binding KindLabel}" Style="{StaticResource Muted}" Margin="0,0,0,8" />
                            <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" FontSize="36" FontWeight="Bold"
                                     Background="Transparent" BorderThickness="0" />
                            <TextBlock Text="{Binding SelectionMetaLine}" Style="{StaticResource Subtle}" Margin="0,0,0,16" />
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource HeroPlayPill}" Command="{Binding PlayAllCommand}" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource IconPlay}" Fill="Black" Stretch="Uniform" Width="14" Height="14" />
                                        <TextBlock Text="{Binding PlayAllLabel}" Margin="10,0,0,0" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource OutlineButton}" Content="{Binding ShuffleLabel}" Command="{Binding ShuffleAllCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Style="{StaticResource GlassPanel}" Padding="12">
                        <ListBox ItemsSource="{Binding FilteredTrackRows}" Style="{StaticResource GlassTrackListBox}">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:CollectionTrackRow}">
                                    <Grid MinHeight="48">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="60" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Grid.ColumnSpan="3" Style="{StaticResource TrackRowHitButton}"
                                                Command="{Binding DataContext.PlayCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding Track}" />
                                        <TextBlock Grid.Column="0" Text="{Binding Index}" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Track.Title}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Track.ArtistName}" Style="{StaticResource Muted}" FontSize="12" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding Track.DurationDisplay}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- Spotify-style add tracks overlay -->
        <Grid Visibility="{Binding ShowAddPanel, Converter={StaticResource BoolToVisibility}}"
              Background="#B0000000">
            <Border Width="440" MaxHeight="560" VerticalAlignment="Center" HorizontalAlignment="Center"
                    CornerRadius="16" Background="#FF18181C" BorderBrush="#28FFFFFF" BorderThickness="1"
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,14">
                        <TextBlock Text="{Binding FindSongsTitle}" FontWeight="Bold" FontSize="18" />
                        <Button Style="{StaticResource IconButton}" HorizontalAlignment="Right" Width="32" Height="32"
                                Command="{Binding ToggleAddPanelCommand}">
                            <Path Data="{StaticResource IconClose}" Fill="{StaticResource TextMutedBrush}"
                                  Stretch="Uniform" Width="14" Height="14" />
                        </Button>
                    </Grid>
                    <Border Grid.Row="1" CornerRadius="10" Background="#14FFFFFF" Padding="10,8" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Path Data="{StaticResource IconSearch}" Fill="{StaticResource TextMutedBrush}"
                                  Stretch="Uniform" Width="16" Height="16" Margin="0,0,8,0" />
                            <TextBox Grid.Column="1" Background="Transparent" BorderThickness="0"
                                     Text="{Binding AddSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="{Binding SearchAddPlaceholder}" />
                        </Grid>
                    </Border>
                    <Button Grid.Row="2" Style="{StaticResource GhostButton}" HorizontalAlignment="Left"
                            Command="{Binding AddCurrentTrackCommand}" Margin="0,0,0,10" Padding="8,6">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconAdd}" Fill="{StaticResource AccentBrush}"
                                  Stretch="Uniform" Width="14" Height="14" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding Loc.PlaylistsAddCurrentTrack}" />
                        </StackPanel>
                    </Button>
                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" MaxHeight="320">
                        <ItemsControl ItemsSource="{Binding AddSearchResults}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:Track}">
                                    <Border Padding="8,10" CornerRadius="8" Margin="0,0,0,4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#18FFFFFF" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding ArtistName}" Style="{StaticResource Muted}" FontSize="12" />
                                            </StackPanel>
                                            <Button Grid.Column="1" Style="{StaticResource PillButton}" Content="{Binding DataContext.AddLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    Command="{Binding DataContext.AddFromSearchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" Padding="14,6" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                        <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource Muted}" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,16,0" TextWrapping="Wrap" MaxWidth="220" />
                        <Button Style="{StaticResource OutlineButton}" Content="{Binding DoneLabel}"
                                Command="{Binding ToggleAddPanelCommand}" Padding="18,8" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
