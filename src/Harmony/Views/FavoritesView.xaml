<UserControl x:Class="Harmony.Views.FavoritesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Harmony.Views"
             xmlns:cmp="clr-namespace:Harmony.Components">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="{StaticResource PagePadding}">

            <!-- Hero -->
            <Border CornerRadius="20" Padding="24,20" Margin="0,0,0,16" ClipToBounds="True"
                    BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#558B5CF6" Offset="0" />
                        <GradientStop Color="#337C3AED" Offset="0.5" />
                        <GradientStop Color="#2838BDF8" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="64" Height="64" CornerRadius="16" Background="#33FFFFFF">
                            <Path Data="{StaticResource IconHeartFilled}" Fill="White" Stretch="Uniform" Width="28" Height="28" />
                        </Border>
                        <StackPanel Margin="18,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SubtitleLabel}" Style="{StaticResource RzMeta}" FontWeight="SemiBold"
                                       Foreground="#E0FFFFFF" />
                            <TextBlock Text="{Binding TitleLabel}" FontSize="32" FontWeight="Bold" Margin="0,2,0,0" />
                            <TextBlock Style="{StaticResource RzBody}" FontSize="13" Margin="0,6,0,0" Foreground="#D0FFFFFF"
                                       Text="{Binding TrackCount, Converter={StaticResource TrackCountLabel}}" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource OutlineButton}" Content="Shuffle"
                                Command="{Binding ShuffleAllCommand}" Margin="0,0,8,0"
                                Visibility="{Binding HasTracks, Converter={StaticResource BoolToVisibility}}" />
                        <Button Style="{StaticResource PillButton}" Command="{Binding PlayAllCommand}" Padding="18,10">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconPlay}" Fill="White" Stretch="Uniform" Width="12" Height="12" />
                                <TextBlock Text="{Binding PlayAllLabel}" Margin="8,0,0,0" FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource GlassPanel}" Padding="10,8" Effect="{x:Null}" VerticalAlignment="Top">
                <Grid>
                    <cmp:EmptyState Title="{Binding EmptyTitleLabel}"
                                    Description="{Binding EmptyDescLabel}"
                                    IconData="{StaticResource IconHeartFilled}"
                                    HorizontalAlignment="Center" Margin="0,24"
                                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}" />

                    <StackPanel Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}">
                        <Grid Margin="8,0,8,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="52" />
                                <ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="{Binding ColumnTitleLabel}" Style="{StaticResource RzMeta}" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="{Binding ColumnTimeLabel}" Style="{StaticResource RzMeta}" FontWeight="SemiBold" HorizontalAlignment="Right" />
                        </Grid>

                        <ListBox ItemsSource="{Binding Tracks}" Style="{StaticResource ActiveTrackListStyle}"
                                 MaxHeight="480" ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <cmp:TrackRow Track="{Binding}"
                                                  PlayCommand="{Binding DataContext.PlayCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                  LikeCommand="{Binding DataContext.UnlikeCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource GlassPanel}" Padding="16" Margin="0,12,0,0" Effect="{x:Null}"
                    Visibility="{Binding ShowRecommendations, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="{Binding AddMoreTitleLabel}" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding AddMoreDescLabel}"
                               Style="{StaticResource RzBody}" Margin="0,6,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
