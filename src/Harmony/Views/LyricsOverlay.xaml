<UserControl x:Class="Harmony.Views.LyricsOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Harmony.ViewModels">
    <Border Background="#FF0A0A0A" Visibility="{Binding IsOpen, Converter={StaticResource BoolToVisibility}}">
        <Grid Margin="32,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding DataContext.Player.CurrentTrack.Title, RelativeSource={RelativeSource AncestorType=Window}}"
                               FontSize="14" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding DataContext.Player.CurrentTrack.ArtistName, RelativeSource={RelativeSource AncestorType=Window}}"
                               Style="{StaticResource Subtle}" FontSize="12" />
                </StackPanel>
                <Button Style="{StaticResource IconButton}" HorizontalAlignment="Right" VerticalAlignment="Top"
                        ToolTip="Close lyrics" Command="{Binding CloseCommand}">
                    <Path Style="{StaticResource IconPath}" Width="16" Height="16" Data="{StaticResource IconClose}" />
                </Button>
            </Grid>

            <TextBlock Grid.Row="1" Text="Loading lyrics…" Style="{StaticResource Subtle}"
                       VerticalAlignment="Center" HorizontalAlignment="Center"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" />

            <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Style="{StaticResource Subtle}"
                       VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap"
                       Visibility="{Binding ShowEmptyMessage, Converter={StaticResource BoolToVisibility}}" />

            <ListBox x:Name="LyricsList" Grid.Row="1"
                     ItemsSource="{Binding Lines}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.CanContentScroll="False">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0,10" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:LyricLineViewModel}">
                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap" TextAlignment="Left"
                                   FontSize="32" FontWeight="Bold" LineHeight="42">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#FF5A5A5A" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPast}" Value="True">
                                            <Setter Property="Foreground" Value="#FF6A6A6A" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter Property="Foreground" Value="White" />
                                            <Setter Property="TextDecorations" Value="Underline" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</UserControl>
