<UserControl x:Class="Harmony.Views.NowPlayingPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:img="clr-namespace:Harmony.Helpers"
             xmlns:services="clr-namespace:Harmony.Services">
    <Border Style="{StaticResource GlassContextPanel}" Margin="0,8,12,8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,14">
                <TextBlock Text="Context" FontWeight="Bold" FontSize="15" VerticalAlignment="Center" />
                <Button Style="{StaticResource IconButton}" Width="32" Height="32" HorizontalAlignment="Right"
                        ToolTip="Close"
                        Command="{Binding DataContext.ToggleNowPlayingCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                    <Path Style="{StaticResource IconPath}" Width="14" Height="14" Data="{StaticResource IconClose}" />
                </Button>
            </Grid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
                <Button Content="Now Playing" Command="{Binding SelectNowPlayingCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PanelTabButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsNowPlayingTab}" Value="True">
                                    <Setter Property="Background" Value="#1AFFFFFF" />
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="Queue" Command="{Binding SelectQueueCommand}" Margin="6,0,0,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PanelTabButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsQueueTab}" Value="True">
                                    <Setter Property="Background" Value="#1AFFFFFF" />
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="Lyrics" Command="{Binding SelectLyricsCommand}" Margin="6,0,0,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PanelTabButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLyricsTab}" Value="True">
                                    <Setter Property="Background" Value="#1AFFFFFF" />
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- Now Playing tab (Spotify-style) -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsNowPlayingTab, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <Border Height="200" CornerRadius="8" ClipToBounds="True" Background="#FF282828">
                        <Grid>
                            <Path Data="{StaticResource IconNote}" Fill="{StaticResource TextMutedBrush}"
                                  Stretch="Uniform" Width="64" Height="64" />
                            <Image img:ImageLoader.SourceUrl="{Binding Player.CurrentTrack.ThumbnailUrl}"
                                   img:ImageLoader.DecodeWidth="320" Stretch="UniformToFill" />
                        </Grid>
                    </Border>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="{Binding Player.CurrentTrack.Title, FallbackValue='Nothing playing'}"
                                       FontSize="22" FontWeight="Bold" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding Player.CurrentTrack.ArtistName}" Style="{StaticResource Muted}"
                                       FontSize="14" Margin="0,4,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                            <Button Style="{StaticResource IconButton}" Width="36" Height="36" Margin="0,0,4,0"
                                    ToolTip="{Binding OpenSpotifyLabel}" Command="{Binding OpenTrackOnSpotifyCommand}">
                                <Path Data="M4 4h6v16H4zm10 0h6v16h-6z" Fill="{StaticResource TextSecondaryBrush}"
                                      Stretch="Uniform" Width="16" Height="16" />
                            </Button>
                            <Button Style="{StaticResource IconButton}" Width="36" Height="36"
                                    ToolTip="Добавить в плейлист" Command="{Binding AddCurrentToPlaylistCommand}">
                                <Path Data="{StaticResource IconAdd}" Fill="{StaticResource TextSecondaryBrush}"
                                      Stretch="Uniform" Width="18" Height="18" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- About the artist -->
                    <Border Background="#FF181818" CornerRadius="8" Padding="16" Margin="0,20,0,0"
                            Visibility="{Binding HasTrack, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="{Binding AboutArtistLabel}" FontWeight="Bold" FontSize="15" Margin="0,0,0,12" />
                            <Border Height="120" CornerRadius="6" ClipToBounds="True" Margin="0,0,0,12" Background="#FF333333">
                                <Grid>
                                    <Path Data="{StaticResource IconAccount}" Fill="#66FFFFFF"
                                          Stretch="Uniform" Width="48" Height="48" />
                                    <Image img:ImageLoader.SourceUrl="{Binding ArtistImageUrl}"
                                           img:ImageLoader.DecodeWidth="240" Stretch="UniformToFill" />
                                    <Button Style="{StaticResource TrackRowHitButton}" Command="{Binding OpenArtistPageCommand}" />
                                </Grid>
                            </Border>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Button Style="{StaticResource GhostButton}" Padding="0" Command="{Binding OpenArtistPageCommand}">
                                    <TextBlock Text="{Binding PrimaryArtistName}" FontWeight="Bold" FontSize="16" />
                                </Button>
                                <Ellipse Width="14" Height="14" Fill="#FF1DB954" Margin="8,0,0,0"
                                         VerticalAlignment="Center"
                                         Visibility="{Binding DeezerArtistId, Converter={StaticResource NullToVisibility}}" />
                            </StackPanel>
                            <TextBlock Text="{Binding FansLine}" Style="{StaticResource Muted}" FontSize="12"
                                       Margin="0,0,0,10"
                                       Visibility="{Binding FansLine, Converter={StaticResource NullToVisibility}}" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Style="{StaticResource OutlineButton}" Content="{Binding FollowSpotifyLabel}"
                                        Command="{Binding OpenPrimaryArtistOnSpotifyCommand}" Padding="16,6" Margin="0,0,8,0" />
                                <Button Style="{StaticResource OutlineButton}" Content="Профиль"
                                        Command="{Binding OpenArtistPageCommand}" Padding="16,6" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Credits -->
                    <Border Background="#FF181818" CornerRadius="8" Padding="16" Margin="0,12,0,0"
                            Visibility="{Binding HasTrack, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="{Binding CreditsLabel}" FontWeight="Bold" FontSize="15" />
                                <TextBlock Text="{Binding ShowAllCreditsLabel}" Style="{StaticResource Muted}"
                                           HorizontalAlignment="Right" FontSize="12" VerticalAlignment="Center" />
                            </Grid>
                            <ItemsControl ItemsSource="{Binding Credits}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type services:TrackCreditLine}">
                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" />
                                                <TextBlock Text="{Binding Role}" Style="{StaticResource Muted}" FontSize="12" Margin="0,2,0,0" />
                                            </StackPanel>
                                            <Button Grid.Column="1" Style="{StaticResource OutlineButton}"
                                                    Content="{Binding DataContext.FollowSpotifyLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    Command="{Binding DataContext.OpenCreditOnSpotifyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" Padding="14,6" FontSize="12" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Queue teaser -->
                    <Border Background="#FF181818" CornerRadius="8" Padding="16" Margin="0,12,0,8">
                        <StackPanel>
                            <TextBlock Text="{Binding QueueEmptyTitle}" FontWeight="SemiBold" FontSize="14"
                                       Visibility="{Binding IsQueueEmpty, Converter={StaticResource BoolToVisibility}}" />
                            <TextBlock Text="Up next" Style="{StaticResource Muted}" FontSize="11" FontWeight="Bold"
                                       Visibility="{Binding HasQueueItems, Converter={StaticResource BoolToVisibility}}" />
                            <Button Style="{StaticResource OutlineButton}" Content="{Binding SearchNewLabel}"
                                    Command="{Binding GoSearchCommand}" HorizontalAlignment="Stretch"
                                    Padding="14,10" Margin="0,12,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Queue tab -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsQueueTab, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="Up next" Style="{StaticResource Muted}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding QueueEmptyTitle}" Style="{StaticResource Muted}" Margin="0,8,0,0"
                               Visibility="{Binding IsQueueEmpty, Converter={StaticResource BoolToVisibility}}" />
                    <ListBox ItemsSource="{Binding Player.UpNext}" Style="{StaticResource TrackListBox}"
                             Visibility="{Binding HasQueueItems, Converter={StaticResource BoolToVisibility}}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="36" Height="36" CornerRadius="6" ClipToBounds="True">
                                        <Image img:ImageLoader.SourceUrl="{Binding ThumbnailUrl}"
                                               img:ImageLoader.DecodeWidth="96" Stretch="UniformToFill" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding ArtistName}" Style="{StaticResource Muted}" FontSize="11" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </ScrollViewer>

            <!-- Lyrics tab -->
            <StackPanel Grid.Row="2"
                        Visibility="{Binding IsLyricsTab, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="Open synced lyrics in the overlay for the best experience."
                           Style="{StaticResource Subtle}" TextWrapping="Wrap" Margin="0,0,0,16" />
                <Button Style="{StaticResource PillButton}" Content="Open lyrics"
                        HorizontalAlignment="Left" Command="{Binding OpenFullLyricsCommand}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
