<UserControl x:Class="Harmony.Views.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Harmony.Views"
             xmlns:cmp="clr-namespace:Harmony.Components">
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="200" />
        </Grid.RowDefinitions>

        <!-- Header + actions -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="{Binding Loc.LibraryTitle}" Style="{StaticResource RzPageTitle}" FontSize="34" />
                <TextBlock Text="{Binding Loc.LibrarySubtitle}" Style="{StaticResource RzBody}" Margin="0,4,0,0"
                           Visibility="{Binding Loc.LibrarySubtitle, Converter={StaticResource NullToVisibility}}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource OutlineButton}" Content="{Binding ImportFolderLabel}"
                        Command="{Binding ImportFolderCommand}" Margin="0,0,8,0" />
                <Button Style="{StaticResource PillButton}" Content="{Binding Loc.LibraryImport}"
                        Command="{Binding ImportFromPcCommand}" />
            </StackPanel>
        </Grid>

        <!-- Stats -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <cmp:StatCard Label="{Binding StatTracksLabel}" Value="{Binding TotalTracks}" />
            <cmp:StatCard Label="{Binding StatArtistsLabel}" Value="{Binding TotalArtists}" />
            <cmp:StatCard Label="{Binding StatAlbumsLabel}" Value="{Binding TotalAlbums}" />
            <cmp:StatCard Label="{Binding StatDurationLabel}" Value="{Binding TotalDurationDisplay}" />
        </StackPanel>

        <!-- Toolbar -->
        <Border Grid.Row="2" Style="{StaticResource GlassPanel}" Padding="12,10" Margin="0,0,0,12" Effect="{x:Null}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="180" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource RzSearchBox}" Margin="0,0,10,0">
                    <Grid>
                        <Path Data="{StaticResource IconSearch}" Fill="{StaticResource TextMutedBrush}"
                              Stretch="Uniform" Width="16" Height="16" Margin="12,0,0,0"
                              VerticalAlignment="Center" HorizontalAlignment="Left" />
                        <TextBox Style="{StaticResource RzSearchTextBox}" Margin="36,0,8,0"
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="Поиск в библиотеке…" />
                    </Grid>
                </Border>
                <TextBlock Grid.Column="1" Text="{Binding Loc.CommonFilterArtist}" Style="{StaticResource RzMeta}"
                           VerticalAlignment="Center" Margin="0,0,8,0" />
                <ComboBox Grid.Column="2" Width="200"
                          ItemsSource="{Binding Artists}"
                          SelectedItem="{Binding SelectedArtist, Mode=TwoWay}" />
            </Grid>
        </Border>

        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Style="{StaticResource Subtle}"
                   Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"
                   Visibility="{Binding StatusMessage, Converter={StaticResource NullToVisibility}}" />

        <!-- Smart playlists row -->
        <ItemsControl Grid.Row="4" ItemsSource="{Binding SmartPlaylists}" Margin="0,0,0,12"
                      Visibility="{Binding HasSmartPlaylists, Converter={StaticResource BoolToVisibility}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Style="{StaticResource GlassQuickCard}" Width="200" MinHeight="56" Margin="0,0,10,0"
                            Command="{Binding DataContext.PlaySmartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}">
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="{Binding Subtitle}" Style="{StaticResource RzMeta}" Margin="0,2,0,0" />
                        </StackPanel>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Track list -->
        <Border Grid.Row="5" Style="{StaticResource GlassPanel}" Padding="10,8" Effect="{x:Null}"
                MaxWidth="920" HorizontalAlignment="Stretch">
            <Grid>
                <cmp:EmptyState Title="{Binding Loc.LibraryEmpty}"
                                Description="Импортируйте папку или добавьте треки с компьютера."
                                ActionText="{Binding Loc.LibraryImport}"
                                ActionCommand="{Binding ImportFromPcCommand}"
                                IconData="{StaticResource IconLibrary}"
                                HorizontalAlignment="Center" Margin="0,24"
                                Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}" />

                <Grid Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="8,0,8,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="88" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="1" Text="Название" Style="{StaticResource RzMeta}" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="2" Text="Альбом" Style="{StaticResource RzMeta}" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="3" Text="Время" Style="{StaticResource RzMeta}" FontWeight="SemiBold" HorizontalAlignment="Right" />
                    </Grid>

                    <ListBox Grid.Row="1" ItemsSource="{Binding Tracks}" Style="{StaticResource ActiveTrackListStyle}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <cmp:TrackRow Track="{Binding}"
                                              ShowAlbum="True"
                                              PlayCommand="{Binding DataContext.PlayCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                              PlaylistCommand="{Binding DataContext.AddToPlaylistCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                              LikeCommand="{Binding DataContext.LikeCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                              RemoveCommand="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
