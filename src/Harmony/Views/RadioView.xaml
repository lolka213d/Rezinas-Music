<UserControl x:Class="Harmony.Views.RadioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Harmony.ViewModels"
             xmlns:cmp="clr-namespace:Harmony.Components"
             VerticalAlignment="Stretch">
    <Grid Margin="{StaticResource PagePadding}" VerticalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Station list -->
        <Grid Grid.Column="0" Margin="0,0,20,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{Binding TitleLabel}" Style="{StaticResource RzPageTitle}" FontSize="28" Margin="0,0,0,4" />
            <TextBlock Grid.Row="1" Text="{Binding SubtitleLabel}" Style="{StaticResource RzMeta}" TextWrapping="Wrap" Margin="0,0,0,16" />

            <ListBox x:Name="StationList" Grid.Row="2"
                     ItemsSource="{Binding Stations}"
                     SelectedItem="{Binding SelectedStation, Mode=TwoWay}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,6" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="bd" CornerRadius="12" Padding="10,8"
                                            Background="#10FFFFFF" BorderBrush="Transparent" BorderThickness="1"
                                            Cursor="Hand">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#228B5CF6" />
                                            <Setter TargetName="bd" Property="BorderBrush" Value="#558B5CF6" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#18FFFFFF" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:RadioStationItem}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="44" Height="44" CornerRadius="10" Margin="0,0,10,0"
                                    Background="{Binding AccentColor, Converter={StaticResource HexToBrush}}">
                                <Path Data="{StaticResource IconRadio}" Fill="White" Stretch="Uniform"
                                      Width="20" Height="20" Opacity="0.95" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Subtitle}" Style="{StaticResource RzMeta}" FontSize="11"
                                           TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                            </StackPanel>
                            <Button Grid.Column="2" Style="{StaticResource IconButton}" Width="32" Height="32"
                                    VerticalAlignment="Center" ToolTip="{Binding DataContext.PlayLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Command="{Binding DataContext.SelectAndPlayCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}">
                                <Path Data="{StaticResource IconPlay}" Fill="{StaticResource TextPrimaryBrush}"
                                      Stretch="Uniform" Width="14" Height="14" />
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- Station queue -->
        <Border Grid.Column="1" CornerRadius="24" ClipToBounds="True" VerticalAlignment="Stretch"
                BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1">
            <Grid>
                <Border>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#338B5CF6" Offset="0" />
                            <GradientStop Color="#FF07080D" Offset="0.55" />
                            <GradientStop Color="#FF07080D" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <Grid Margin="24,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedStationTitle, FallbackValue=—}"
                                       FontSize="28" FontWeight="Bold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource RzMeta}"
                                       Margin="0,4,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource PlayButton}" Width="52" Height="52"
                                    Command="{Binding PlayStationCommand}"
                                    IsEnabled="{Binding CanPlay}" Margin="0,0,10,0">
                                <Path Data="{StaticResource IconPlay}" Fill="White" Stretch="Uniform" Width="18" Height="18" />
                            </Button>
                            <Button Style="{StaticResource OutlineButton}" Content="{Binding PlayLabel}"
                                    Command="{Binding PlayStationCommand}" IsEnabled="{Binding CanPlay}"
                                    Padding="20,11" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <ProgressBar Grid.Row="1" IsIndeterminate="True" Height="3" Margin="0,0,0,12"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" />

                    <Border Grid.Row="2" Style="{StaticResource GlassPanel}" Padding="10,8" Effect="{x:Null}">
                        <Grid>
                            <cmp:EmptyState Title="{Binding EmptyLabel}"
                                            Description="{Binding SubtitleLabel}"
                                            IconData="{StaticResource IconRadio}"
                                            HorizontalAlignment="Center" Margin="0,40"
                                            Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}" />

                            <Grid Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="{Binding QueueTitleLabel}"
                                           FontSize="15" FontWeight="SemiBold" Margin="8,0,8,4" />

                                <Grid Grid.Row="1" Margin="8,0,8,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="52" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="2" Text="{Binding ColumnTitleLabel}"
                                               Style="{StaticResource RzMeta}" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="3" Text="{Binding ColumnTimeLabel}"
                                               Style="{StaticResource RzMeta}" FontWeight="SemiBold" HorizontalAlignment="Right" />
                                </Grid>

                                <ListBox x:Name="TrackList" Grid.Row="2" ItemsSource="{Binding Tracks}"
                                         Style="{StaticResource ActiveTrackListStyle}"
                                         AlternationCount="10000"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <cmp:TrackRow Track="{Binding}"
                                                          ShowIndex="True"
                                                          ShowPlayButton="False"
                                                          CurrentTrack="{Binding DataContext.Player.CurrentTrack, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                          PlayCommand="{Binding DataContext.PlayTrackCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                          Index="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=(ItemsControl.AlternationIndex), Converter={StaticResource TrackNumber}}" />
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
