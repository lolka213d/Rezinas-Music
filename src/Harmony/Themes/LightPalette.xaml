<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Harmony light palette — overlays DarkTheme styles without replacing them. -->
    <Color x:Key="BackgroundDeepColor">#FFE8E8ED</Color>
    <Color x:Key="BackgroundColor">#FFF3F3F8</Color>
    <Color x:Key="BackgroundElevatedColor">#FFFFFFFF</Color>
    <Color x:Key="SidebarColor">#FF1A1A22</Color>
    <Color x:Key="SurfaceColor">#CCFFFFFF</Color>
    <Color x:Key="SurfaceHoverColor">#E6FFFFFF</Color>
    <Color x:Key="AccentColor">#FF7C3AED</Color>
    <Color x:Key="AccentVioletColor">#FF8B5CF6</Color>
    <Color x:Key="AccentBlueColor">#FF0EA5E9</Color>
    <Color x:Key="TextPrimaryColor">#FF111118</Color>
    <Color x:Key="TextSecondaryColor">#FF4B5563</Color>
    <Color x:Key="TextMutedColor">#FF6B7280</Color>
    <Color x:Key="GlassBorderColor">#33000000</Color>

    <SolidColorBrush x:Key="BackgroundDeepBrush" Color="{StaticResource BackgroundDeepColor}" />
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="BackgroundElevatedBrush" Color="{StaticResource BackgroundElevatedColor}" />
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource SurfaceHoverColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentVioletBrush" Color="{StaticResource AccentVioletColor}" />
    <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlueColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />
    <SolidColorBrush x:Key="GlassBorderSolidBrush" Color="{StaticResource GlassBorderColor}" />

    <LinearGradientBrush x:Key="AppBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFE8E8ED" Offset="0" />
        <GradientStop Color="#FFF3F3F8" Offset="0.45" />
        <GradientStop Color="#FFFFFFFF" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentGlowBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#337C3AED" Offset="0" />
        <GradientStop Color="#228B5CF6" Offset="0.55" />
        <GradientStop Color="#180EA5E9" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="GlassFillBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#CCFFFFFF" Offset="0" />
        <GradientStop Color="#AAFFFFFF" Offset="0.5" />
        <GradientStop Color="#88FFFFFF" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="GlassFillHoverBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#EEFFFFFF" Offset="0" />
        <GradientStop Color="#DDFFFFFF" Offset="0.5" />
        <GradientStop Color="#CCFFFFFF" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="GlassBorderBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#44000000" Offset="0" />
        <GradientStop Color="#22000000" Offset="0.5" />
        <GradientStop Color="#33000000" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="GlassInnerHighlightBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#55FFFFFF" Offset="0" />
        <GradientStop Color="#00FFFFFF" Offset="0.35" />
    </LinearGradientBrush>

</ResourceDictionary>
