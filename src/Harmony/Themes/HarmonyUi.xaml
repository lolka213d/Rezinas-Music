<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Unified glass styles (matches DarkTheme / Aurora) -->

    <Style x:Key="HarmonyPillSearch" TargetType="Border" BasedOn="{StaticResource GlassPanel}">
        <Setter Property="CornerRadius" Value="24" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="MinHeight" Value="48" />
        <Setter Property="Effect" Value="{x:Null}" />
    </Style>

    <Style x:Key="HarmonyHistoryPill" TargetType="Border" BasedOn="{StaticResource GlassPanel}">
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Effect" Value="{x:Null}" />
    </Style>

    <Style x:Key="HarmonySuggestionPill" TargetType="Border" BasedOn="{StaticResource GlassPanel}">
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="Margin" Value="0,0,0,6" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Effect" Value="{x:Null}" />
    </Style>

    <Style x:Key="HarmonyFilterChip" TargetType="Button" BasedOn="{StaticResource FilterChip}" />

    <Style x:Key="HarmonyFilterChipActive" TargetType="Button" BasedOn="{StaticResource FilterChipActive}" />

    <Style x:Key="HarmonyLibraryTile" TargetType="Button">
        <Setter Property="Width" Value="148" />
        <Setter Property="Height" Value="168" />
        <Setter Property="Margin" Value="0,0,14,14" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <StackPanel>
                        <Border Width="148" Height="148" CornerRadius="16" ClipToBounds="True"
                                BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#338B5CF6" Offset="0" />
                                    <GradientStop Color="#2238BDF8" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Path Data="{TemplateBinding Tag}" Fill="White" Stretch="Uniform"
                                  Width="40" Height="40" Opacity="0.9" />
                        </Border>
                        <TextBlock Text="{TemplateBinding Content}" Foreground="{StaticResource TextPrimaryBrush}"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,8,0,0"
                                   HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="148" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="0.92" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HarmonySettingsExpander" TargetType="Expander">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Expander">
                    <Border Style="{StaticResource GlassPanel}" Padding="4" Effect="{x:Null}">
                        <DockPanel>
                            <ToggleButton x:Name="HeaderSite" DockPanel.Dock="Top"
                                          IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="14,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0" Content="{TemplateBinding Header}"
                                                      VerticalAlignment="Center" />
                                    <Path Grid.Column="1" Data="M7 10l5 5 5-5z" Fill="{StaticResource TextMutedBrush}"
                                          Stretch="Uniform" Width="14" Height="14" />
                                </Grid>
                            </ToggleButton>
                            <ContentPresenter x:Name="ExpandSite" DockPanel.Dock="Bottom"
                                              Visibility="Collapsed" Margin="14,0,14,12" />
                        </DockPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HarmonyDiscoverRow" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="bd" Background="Transparent" CornerRadius="10" Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceHoverBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HarmonyFab" TargetType="Button">
        <Setter Property="Width" Value="48" />
        <Setter Property="Height" Value="48" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="24">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.35" Color="#8B5CF6" />
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="0.9" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SettingsNavButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="Margin" Value="0,0,0,4" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="12"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#14FFFFFF" />
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
