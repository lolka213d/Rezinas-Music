<UserControl x:Class="Harmony.Components.PlaylistCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root" Width="168" Margin="0,0,14,14">
    <Button Cursor="Hand" Background="Transparent" BorderThickness="0" Padding="0"
            Command="{Binding Command, ElementName=Root}"
            CommandParameter="{Binding CommandParameter, ElementName=Root}">
        <Button.Template>
            <ControlTemplate TargetType="Button">
                <StackPanel>
                    <Border x:Name="cover" Width="168" Height="168" CornerRadius="16" ClipToBounds="True"
                            BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1">
                        <Grid>
                            <Border>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#448B5CF6" Offset="0" />
                                        <GradientStop Color="#2838BDF8" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <Path Data="{StaticResource IconPlaylist}" Fill="White" Stretch="Uniform"
                                  Width="48" Height="48" Opacity="0.9" />
                            <Border Background="#77000000" Opacity="0" x:Name="playOverlay">
                                <Border Width="44" Height="44" CornerRadius="22"
                                        Background="{StaticResource PrimaryButtonBrush}"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path Data="{StaticResource IconPlay}" Fill="White" Stretch="Uniform"
                                          Width="16" Height="16" Margin="2,0,0,0" />
                                </Border>
                            </Border>
                        </Grid>
                    </Border>
                    <TextBlock Text="{Binding Title, ElementName=Root}" FontWeight="SemiBold" FontSize="14"
                               Margin="2,10,2,0" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Subtitle, ElementName=Root}" Style="{StaticResource RzMeta}"
                               Margin="2,4,2,0" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="playOverlay" Property="Opacity" Value="1" />
                        <Setter TargetName="cover" Property="BorderBrush" Value="#668B5CF6" />
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Button.Template>
    </Button>
</UserControl>
