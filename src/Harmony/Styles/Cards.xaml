<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="GlassPanel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource GlassFillBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.28" Color="Black" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GlassHeroCard" TargetType="Border" BasedOn="{StaticResource GlassPanel}">
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="24,20" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="Effect" Value="{x:Null}" />
    </Style>

    <Style x:Key="GlassQuickCard" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource GlassFillBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="MinHeight" Value="64" />
        <Setter Property="Margin" Value="0,0,12,12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="16" Padding="14,12"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </Border.RenderTransform>
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource GlassFillHoverBrush}" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="#598B5CF6" />
                            <Setter TargetName="bd" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1.02" ScaleY="1.02" />
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="bd" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.3" Color="#8B5CF6" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GlassTrackCard" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource GlassFillBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Width" Value="156" />
        <Setter Property="Margin" Value="0,0,12,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1" CornerRadius="16" ClipToBounds="True"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </Border.RenderTransform>
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource GlassFillHoverBrush}" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="#668B5CF6" />
                            <Setter TargetName="bd" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1.03" ScaleY="1.03" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="RzStatCard" TargetType="Border" BasedOn="{StaticResource GlassPanel}">
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="MinWidth" Value="120" />
        <Setter Property="Effect" Value="{x:Null}" />
    </Style>

    <Style x:Key="RzNewPlaylistCard" TargetType="Button">
        <Setter Property="Width" Value="168" />
        <Setter Property="Height" Value="200" />
        <Setter Property="Margin" Value="0,0,14,14" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" CornerRadius="18"
                            BorderBrush="#338B5CF6" BorderThickness="1.5"
                            Background="#08FFFFFF">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Border Width="48" Height="48" CornerRadius="24" Background="#188B5CF6" Margin="0,0,0,10">
                                <Path Data="{StaticResource IconAdd}" Fill="{StaticResource AccentBrush}"
                                      Stretch="Uniform" Width="20" Height="20" />
                            </Border>
                            <TextBlock Text="{DynamicResource NewPlaylistCardLabel}" FontWeight="SemiBold" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#12FFFFFF" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="#888B5CF6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
