<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Rezinas Music — premium dark palette -->
    <Color x:Key="BackgroundDeepColor">#FF07080D</Color>
    <Color x:Key="BackgroundColor">#FF0B0D14</Color>
    <Color x:Key="BackgroundElevatedColor">#FF10131C</Color>
    <Color x:Key="SidebarColor">#FF07080D</Color>
    <Color x:Key="SurfaceColor">#0BFFFFFF</Color>
    <Color x:Key="SurfaceHoverColor">#14FFFFFF</Color>
    <Color x:Key="CardColor">#0FFFFFFF</Color>
    <Color x:Key="AccentColor">#FF8B5CF6</Color>
    <Color x:Key="AccentBrightColor">#FFA855F7</Color>
    <Color x:Key="AccentVioletColor">#FF7C3AED</Color>
    <Color x:Key="AccentCyanColor">#FF22D3EE</Color>
    <Color x:Key="AccentBlueColor">#FF38BDF8</Color>
    <Color x:Key="AccentGreenColor">#FF10B981</Color>
    <Color x:Key="TextPrimaryColor">#FFF8FAFC</Color>
    <Color x:Key="TextSecondaryColor">#FFA1AABD</Color>
    <Color x:Key="TextMutedColor">#FF6B7280</Color>
    <Color x:Key="TextDisabledColor">#FF4B5563</Color>
    <Color x:Key="GlassBorderColor">#14FFFFFF</Color>
    <Color x:Key="GlassBorderHoverColor">#598B5CF6</Color>
    <Color x:Key="GlassBorderActiveColor">#8CA855F7</Color>

    <SolidColorBrush x:Key="BackgroundDeepBrush" Color="{StaticResource BackgroundDeepColor}" />
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="BackgroundElevatedBrush" Color="{StaticResource BackgroundElevatedColor}" />
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource SurfaceHoverColor}" />
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentBrightBrush" Color="{StaticResource AccentBrightColor}" />
    <SolidColorBrush x:Key="AccentVioletBrush" Color="{StaticResource AccentVioletColor}" />
    <SolidColorBrush x:Key="AccentCyanBrush" Color="{StaticResource AccentCyanColor}" />
    <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlueColor}" />
    <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreenColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}" />
    <SolidColorBrush x:Key="GlassBorderSolidBrush" Color="{StaticResource GlassBorderColor}" />

    <LinearGradientBrush x:Key="AppBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF07080D" Offset="0" />
        <GradientStop Color="#FF0B0D14" Offset="0.5" />
        <GradientStop Color="#FF10131C" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentGlowBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#558B5CF6" Offset="0" />
        <GradientStop Color="#447C3AED" Offset="0.5" />
        <GradientStop Color="#3338BDF8" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="PrimaryButtonBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF8B5CF6" Offset="0" />
        <GradientStop Color="#FFA855F7" Offset="0.55" />
        <GradientStop Color="#FF7C3AED" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ProgressFillBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FF8B5CF6" Offset="0" />
        <GradientStop Color="#FF22D3EE" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="GlassFillBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#0FFFFFFF" Offset="0" />
        <GradientStop Color="#080B1220" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="GlassFillHoverBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#18FFFFFF" Offset="0" />
        <GradientStop Color="#0CFFFFFF" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="GlassBorderBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#14FFFFFF" Offset="0" />
        <GradientStop Color="#228B5CF6" Offset="0.5" />
        <GradientStop Color="#14FFFFFF" Offset="1" />
    </LinearGradientBrush>

    <Thickness x:Key="PagePadding">28,24,28,100</Thickness>
    <Thickness x:Key="CardPadding">16,14</Thickness>

</ResourceDictionary>
