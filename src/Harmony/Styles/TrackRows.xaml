<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="TrackListBox" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="False" />
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style x:Key="RzTrackRowItem" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="MinHeight" Value="52" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="bd" CornerRadius="10" Padding="8,6"
                            Background="Transparent" BorderThickness="1"
                            BorderBrush="Transparent">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#14FFFFFF" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="#22FFFFFF" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#228B5CF6" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="#558B5CF6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ActiveTrackListStyle" TargetType="ListBox" BasedOn="{StaticResource TrackListBox}">
        <Setter Property="ItemContainerStyle" Value="{StaticResource RzTrackRowItem}" />
    </Style>

    <Style x:Key="RzTrackListHeader" TargetType="Grid">
        <Setter Property="Margin" Value="8,0,8,6" />
    </Style>

    <Style x:Key="RzTrackCover" TargetType="Border">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="Background" Value="#12FFFFFF" />
        <Setter Property="Margin" Value="8,0,0,0" />
    </Style>

    <Style x:Key="GlassTrackListBox" TargetType="ListBox" BasedOn="{StaticResource TrackListBox}">
        <Setter Property="ItemContainerStyle" Value="{StaticResource RzTrackRowItem}" />
    </Style>

</ResourceDictionary>
