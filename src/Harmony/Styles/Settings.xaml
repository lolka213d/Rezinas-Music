<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="RzSettingRow" TargetType="Border">
        <Setter Property="Padding" Value="0,12" />
        <Setter Property="BorderBrush" Value="#12FFFFFF" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style x:Key="RzSettingsSection" TargetType="Border" BasedOn="{StaticResource GlassPanel}">
        <Setter Property="Padding" Value="18,14" />
        <Setter Property="Margin" Value="0,0,0,12" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Effect" Value="{x:Null}" />
    </Style>

    <Style x:Key="RzSettingsSidebar" TargetType="Border" BasedOn="{StaticResource GlassPanel}">
        <Setter Property="Padding" Value="8" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Effect" Value="{x:Null}" />
    </Style>

</ResourceDictionary>
