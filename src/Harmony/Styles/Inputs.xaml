<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="RzSearchBox" TargetType="Border">
        <Setter Property="Background" Value="#0CFFFFFF" />
        <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="MinHeight" Value="50" />
        <Setter Property="Padding" Value="6,4" />
    </Style>

    <Style x:Key="RzSearchTextBox" TargetType="TextBox" BasedOn="{StaticResource GlassInput}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Padding" Value="10,12" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
    </Style>

    <Style x:Key="RzToolbarCombo" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="MinWidth" Value="180" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Background" Value="#14FFFFFF" />
        <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}" />
    </Style>

    <!-- Glass ComboBox for all screens (keeps dark dropdown template from DarkTheme) -->
    <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
        <Setter Property="Background" Value="#14FFFFFF" />
        <Setter Property="BorderBrush" Value="#28FFFFFF" />
        <Setter Property="MinHeight" Value="40" />
    </Style>

</ResourceDictionary>
