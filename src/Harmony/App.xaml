<Application x:Class="Harmony.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Harmony.ViewModels"
             xmlns:views="clr-namespace:Harmony.Views"
             xmlns:conv="clr-namespace:Harmony.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Icons.xaml" />
                <ResourceDictionary Source="Themes/DarkTheme.xaml" />
                <ResourceDictionary Source="Themes/HarmonyUi.xaml" />
                <ResourceDictionary Source="Themes/Animations.xaml" />
                <ResourceDictionary Source="Styles/Colors.xaml" />
                <ResourceDictionary Source="Styles/Typography.xaml" />
                <ResourceDictionary Source="Styles/Buttons.xaml" />
                <ResourceDictionary Source="Styles/Inputs.xaml" />
                <ResourceDictionary Source="Styles/Cards.xaml" />
                <ResourceDictionary Source="Styles/TrackRows.xaml" />
                <ResourceDictionary Source="Styles/Player.xaml" />
                <ResourceDictionary Source="Styles/Settings.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters shared across views -->
            <conv:PlayPauseGlyphConverter x:Key="PlayPauseGlyph" />
            <conv:NullToVisibilityConverter x:Key="NullToVisibility" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
            <conv:VolumeToWidthConverter x:Key="VolumeToWidth" />
            <conv:TrackNumberConverter x:Key="TrackNumber" />
            <conv:FilterChipSelectedConverter x:Key="FilterChipSelected" />
            <conv:IsSameTrackConverter x:Key="IsSameTrack" />
            <conv:AudioQualityLabelConverter x:Key="AudioQualityLabel" />
            <conv:TrackIsFavoriteConverter x:Key="TrackIsFavorite" />
            <conv:TrackCountLabelConverter x:Key="TrackCountLabel" />
            <conv:HexToBrushConverter x:Key="HexToBrush" />

            <sys:String x:Key="NewPlaylistCardLabel" xmlns:sys="clr-namespace:System;assembly=mscorlib">New playlist</sys:String>

            <!-- Map each page view model to its view. The ContentControl in the
                 main window uses these to render the current page. -->
            <DataTemplate DataType="{x:Type vm:HomeViewModel}">
                <views:HomeView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SearchViewModel}">
                <views:SearchView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:LibraryHubViewModel}">
                <views:LibraryHubView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:LibraryViewModel}">
                <views:LibraryView VerticalAlignment="Stretch" HorizontalAlignment="Stretch" />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
                <views:HistoryView HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:FavoritesViewModel}">
                <views:FavoritesView VerticalAlignment="Stretch" HorizontalAlignment="Stretch" />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:PlaylistsViewModel}">
                <views:PlaylistsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:CollectionsViewModel}">
                <views:CollectionsView VerticalAlignment="Stretch" HorizontalAlignment="Stretch" />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:AlbumsViewModel}">
                <views:AlbumsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:AlbumDetailViewModel}">
                <views:AlbumDetailView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ArtistDetailViewModel}">
                <views:ArtistDetailView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <views:SettingsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ProfileViewModel}">
                <views:ProfileView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:RadioViewModel}">
                <views:RadioView VerticalAlignment="Stretch" HorizontalAlignment="Stretch" />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
